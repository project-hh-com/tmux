#!/usr/bin/env bash
# skq — Search Keyword Quality 개선 워크플로 (6-Phase 직렬 멀티에이전트)
# 사용법: skq              → 전체 검색 키워드 품질 자동 개선
#         skq "특정 범위"  → 범위/목적을 지정해 실행
#
# 워크플로:
#   Phase A: Discovery    — DB 기반 개선 대상 키워드 자동 발굴
#   Phase B: Analysis     — 각 키워드별 진단 코드 + 구체적 수정 방향 제안
#   Phase C: Plan Debate  — 수정 방향의 도메인 적합성 토론 (Red/Blue/Judge)
#   Phase D: Propose      — 승인된 플랜 기반 병렬 SQL 생성 (5 에이전트)
#   Phase E: Ship-Ready   — 최종 SQL 패키징 + 매니페스트 생성
#   Phase F: Validate     — 예상 개선도 추정 + 리포트
#
# tmux 환경: Phase별 패널로 시각적 병렬 실행
# 비 tmux 환경: 백그라운드 세션으로 실행
#
# 출력: docs/reports/skq-{DATE}/ 폴더
# 적용: ship 명령어로 ship.sql 검토 후 실행

set -euo pipefail

SCOPE="${1:-전체 검색 키워드 품질 개선 — 검색 정확도 및 결과 노출 향상}"

SKQ_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ── 실행 ID / 디렉토리 ────────────────────────────────────────
RUN_DATE="$(date +%Y%m%d-%H%M%S)"
RUN_ID="skq-${RUN_DATE}"
FLAG_DIR="${SKQ_DIR}/.agent/${RUN_ID}"
OUTPUT_DIR="${SKQ_DIR}/docs/reports/${RUN_ID}"

PHASE_D_SHARED="${FLAG_DIR}/phase_d_shared"
mkdir -p "${FLAG_DIR}" "${OUTPUT_DIR}" "${PHASE_D_SHARED}"

PANE_ID_FILE="${FLAG_DIR}/pane_ids.txt"
touch "${PANE_ID_FILE}"

# ── DB 자격증명 ───────────────────────────────────────────────
SQ_DB_ENV="${HOME}/.config/sq/db.env"
if [[ -f "${SQ_DB_ENV}" ]]; then
  # shellcheck source=/dev/null
  source "${SQ_DB_ENV}"
else
  echo "❌ DB 자격증명 파일이 없습니다: ${SQ_DB_ENV}"
  echo "   skq-setup을 먼저 실행하세요."
  exit 1
fi

PGHOST="${PGHOST:-}"
PGDATABASE="${PGDATABASE:-danble}"
PGUSER="${PGUSER:-danble_read_only}"
PGPASSWORD="${PGPASSWORD:-}"
PGPORT="${PGPORT:-5432}"
PGSSLMODE="${PGSSLMODE:-require}"
export PGHOST PGDATABASE PGUSER PGPASSWORD PGPORT PGSSLMODE

# ── 공통 문서 컨텍스트 경로 (에이전트가 Read로 직접 읽음) ─────
PIPELINE_DOC="${SKQ_DIR}/docs/search-pipeline.md"
SCHEMA_DOC="${SKQ_DIR}/docs/db-schema.md"

# ── tmux 환경 감지 ────────────────────────────────────────────
IN_TMUX=0
MAIN_WIN=""
MAIN_PANE=""
if [[ -n "${TMUX:-}" ]]; then
  IN_TMUX=1
  MAIN_WIN=$(tmux display-message -p '#{window_id}')
  MAIN_PANE=$(tmux display-message -p '#{pane_id}')
fi

PHASE_ANCHOR_PANE=""   # 현재 웨이브의 첫 번째 패널 (세로 분할 기준점)

# ═══════════════════════════════════════════════════════════════
# 헬퍼 함수
# ═══════════════════════════════════════════════════════════════

# 에이전트 실행 스크립트 생성
# write_agent_script <script_path> <prompt_path> [allowed_tools] [done_flag]
#   allowed_tools: 기본값 "Bash,Read,Glob,Grep" (읽기 전용)
#   done_flag:     완료 시 touch할 파일 경로 (SubagentStop Hook 역할)
write_agent_script() {
  local SCRIPT_PATH="$1"
  local PROMPT_PATH="$2"
  local ALLOWED_TOOLS="${3:-Bash,Read,Glob,Grep}"
  local DONE_FLAG="${4:-}"

  cat > "${SCRIPT_PATH}" << AGENTSCRIPT
#!/usr/bin/env bash
set -euo pipefail
source "${SQ_DB_ENV}"
export PGHOST PGDATABASE PGUSER PGPASSWORD PGPORT PGSSLMODE
cd "${SKQ_DIR}"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  에이전트 시작: \$(basename "${SCRIPT_PATH}" .sh)"
echo "  툴 권한: ${ALLOWED_TOOLS}"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
claude --dangerously-skip-permissions \\
  --allowedTools "${ALLOWED_TOOLS}" \\
  -p "\$(cat '${PROMPT_PATH}')" \\
  2>&1
EXIT_CODE=\$?
# [Hook: SubagentStop] 에이전트 종료 시 완료 플래그 자동 기록
if [[ -n "${DONE_FLAG}" ]]; then
  echo "\${EXIT_CODE}" > "${DONE_FLAG}.exit"
  touch "${DONE_FLAG}"
fi
AGENTSCRIPT
  chmod +x "${SCRIPT_PATH}"
}

# tmux 패널 실행 또는 백그라운드 세션 실행
# launch_agent <agent_name> <emoji> <script_path> <is_first_in_phase>
# is_first_in_phase: "1"이면 가로 분할, "0"이면 세로 분할
launch_agent() {
  local AGENT_NAME="$1"
  local EMOJI="$2"
  local SCRIPT_PATH="$3"
  local IS_FIRST="${4:-1}"

  if [[ "${IN_TMUX}" -eq 1 ]]; then
    local NEW_PANE
    if [[ "${IS_FIRST}" == "1" ]]; then
      # 첫 에이전트: 메인 패널 오른쪽에 가로 분할 (새 Phase 컬럼)
      tmux split-window -h -t "${MAIN_PANE}" -c "${SKQ_DIR}"
      NEW_PANE=$(tmux display-message -p '#{pane_id}')
      PHASE_ANCHOR_PANE="${NEW_PANE}"
    else
      # 같은 Phase 내 추가 에이전트: 첫 패널 기준 세로 분할
      NEW_PANE=$(tmux split-window -v -t "${PHASE_ANCHOR_PANE}" -c "${SKQ_DIR}" -P -F '#{pane_id}')
    fi
    echo "${NEW_PANE}" >> "${PANE_ID_FILE}"
    tmux select-pane -t "${NEW_PANE}" -T "${EMOJI} ${AGENT_NAME}"
    tmux send-keys -t "${NEW_PANE}" "bash '${SCRIPT_PATH}'" Enter
    tmux select-layout -t "${MAIN_WIN}" main-vertical 2>/dev/null || true
    tmux select-pane -t "${MAIN_PANE}" 2>/dev/null || true
  else
    # 비 tmux 환경: 백그라운드 세션 실행
    local SESSION="skq-${AGENT_NAME}-${RUN_DATE}"
    tmux new-session -d -s "${SESSION}" -c "${SKQ_DIR}" "bash '${SCRIPT_PATH}'; sleep 2" 2>/dev/null || \
      bash "${SCRIPT_PATH}" &
    echo "${SESSION}" >> "${FLAG_DIR}/agent_sessions.txt"
    echo "  └─ ${EMOJI} ${AGENT_NAME} 백그라운드 시작"
  fi
}

# 완료 플래그 폴링 대기
# wait_phase <label> <done_flag...>
wait_phase() {
  local LABEL="$1"; shift
  local FLAGS=("$@")
  local TOTAL="${#FLAGS[@]}"
  local ELAPSED=0
  local MAX_WAIT=600

  while [[ "${ELAPSED}" -lt "${MAX_WAIT}" ]]; do
    local DONE=0
    for flag in "${FLAGS[@]}"; do
      [[ -f "${FLAG_DIR}/${flag}" ]] && DONE=$((DONE + 1)) || true
    done
    if [[ "${DONE}" -ge "${TOTAL}" ]]; then
      printf "\r  ✅ %-30s 완료 (%ds)           \n" "${LABEL}" "${ELAPSED}"
      return 0
    fi
    printf "\r  ⏳ %-30s %d/%d 대기 중... (%ds)  " "${LABEL}" "${DONE}" "${TOTAL}" "${ELAPSED}"
    sleep 5
    ELAPSED=$((ELAPSED + 5))
  done

  echo ""
  echo "  ❌ ${LABEL} 타임아웃 (${MAX_WAIT}s)"
  return 1
}

# 현재 Phase의 패널/세션 정리
cleanup_phase() {
  if [[ "${IN_TMUX}" -eq 1 ]] && [[ -s "${PANE_ID_FILE}" ]]; then
    while IFS= read -r PANE_ID; do
      tmux kill-pane -t "${PANE_ID}" 2>/dev/null || true
    done < "${PANE_ID_FILE}"
    > "${PANE_ID_FILE}"
    tmux select-pane -t "${MAIN_PANE}" 2>/dev/null || true
  fi
  if [[ -f "${FLAG_DIR}/agent_sessions.txt" ]] && [[ -s "${FLAG_DIR}/agent_sessions.txt" ]]; then
    while IFS= read -r SESSION; do
      tmux kill-session -t "${SESSION}" 2>/dev/null || true
    done < "${FLAG_DIR}/agent_sessions.txt"
    > "${FLAG_DIR}/agent_sessions.txt"
  fi
  PHASE_ANCHOR_PANE=""
}

