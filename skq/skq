## 발굴 쿼리 5종 실행

### Q1: ZERO_RESULT — 결과 0건 키워드
\`\`\`sql
SELECT sk.id, sk.keyword, sk.keyword_type, sk.category_main,
       skr.result_product_count, sk.rank
FROM search_keywords sk
JOIN search_keyword_rankings skr ON skr.search_keyword_id = sk.id
WHERE skr.result_product_count = 0
  AND sk.is_deleted = false
ORDER BY sk.rank ASC NULLS LAST
LIMIT 30;
\`\`\`

### Q2: ETC_TYPE — keyword_type이 ETC인 키워드
\`\`\`sql
SELECT sk.id, sk.keyword, sk.keyword_type, sk.category_main,
       skr.result_product_count, sk.rank
FROM search_keywords sk
LEFT JOIN search_keyword_rankings skr ON skr.search_keyword_id = sk.id
WHERE sk.keyword_type = 'ETC'
  AND sk.is_deleted = false
ORDER BY sk.rank ASC NULLS LAST
LIMIT 30;
\`\`\`

### Q3: NO_SYNONYM — SAME 동의어가 없는 키워드
\`\`\`sql
SELECT sk.id, sk.keyword, sk.keyword_type, skr.result_product_count, sk.rank
FROM search_keywords sk
LEFT JOIN search_keyword_rankings skr ON skr.search_keyword_id = sk.id
WHERE sk.is_deleted = false
  AND COALESCE(skr.result_product_count, 0) > 0
  AND NOT EXISTS (
    SELECT 1 FROM search_keyword_relations skrel
    WHERE skrel.source_keyword_id = sk.id
      AND skrel.relation_type = 'SAME'
  )
ORDER BY sk.rank ASC NULLS LAST
LIMIT 30;
\`\`\`

### Q4: POSSIBLE_FALLBACK — 발골사전 미연결 키워드
\`\`\`sql
SELECT sk.id, sk.keyword, sk.keyword_type, sk.category_main,
       skr.result_product_count, sk.rank
FROM search_keywords sk
LEFT JOIN search_keyword_rankings skr ON skr.search_keyword_id = sk.id
WHERE sk.keyword_type IN ('BRAND', 'CATEGORY', 'COLOR')
  AND sk.is_deleted = false
  AND NOT EXISTS (
    SELECT 1 FROM search_brand_keywords WHERE search_keyword_id = sk.id
    UNION ALL
    SELECT 1 FROM search_category_keywords WHERE search_keyword_id = sk.id
    UNION ALL
    SELECT 1 FROM search_color_keywords WHERE search_keyword_id = sk.id
  )
ORDER BY sk.rank ASC NULLS LAST
LIMIT 30;
\`\`\`

### Q5: WRONG_PRIORITY — 우선순위 역전 의심 키워드
\`\`\`sql
-- 5-A: rank 상위인데 priority=100(기본값)
SELECT sk.id, sk.keyword, sk.keyword_type, sk.priority, sk.rank,
       skr.result_product_count
FROM search_keywords sk
LEFT JOIN search_keyword_rankings skr ON skr.search_keyword_id = sk.id
WHERE sk.is_deleted = false
  AND sk.priority = 100
  AND sk.rank IS NOT NULL
  AND sk.rank <= 100
ORDER BY sk.rank ASC
LIMIT 20;

-- 5-B: 토큰 포함 관계 priority 충돌 쌍
SELECT a.id AS id_a, a.keyword AS keyword_a, a.keyword_type AS type_a, a.priority AS priority_a, a.rank AS rank_a,
       b.id AS id_b, b.keyword AS keyword_b, b.keyword_type AS type_b, b.priority AS priority_b, b.rank AS rank_b
FROM search_keywords a
JOIN search_keywords b
  ON b.keyword LIKE '%' || a.keyword || '%'
  AND b.id != a.id
  AND a.is_deleted = false
  AND b.is_deleted = false
  AND a.priority <= b.priority
  AND length(a.keyword) < length(b.keyword)
ORDER BY a.rank ASC NULLS LAST
LIMIT 20;
\`\`\`

