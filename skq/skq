echo "  실행 ID: ${RUN_ID}"
echo "  범위: ${SCOPE}"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

