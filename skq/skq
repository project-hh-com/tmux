#!/usr/bin/env bash
# skq — Search Keyword Quality 개선 워크플로 (6-Wave 직렬 멀티에이전트)
# 사용법: skq              → 전체 검색 키워드 품질 자동 개선
#         skq "특정 범위"  → 범위/목적을 지정해 실행
#
# 워크플로:
#   Wave A: Discovery    — DB 기반 개선 대상 키워드 자동 발굴
#   Wave B: Analysis     — 각 키워드별 진단 코드 + 구체적 수정 방향 제안
#   Wave C: Plan Debate  — 수정 방향의 도메인 적합성 토론 (Red/Blue/Judge)
#   Wave D: Propose      — 승인된 플랜 기반 병렬 SQL 생성 (5 에이전트)
#   Wave E: Ship-Ready   — 최종 SQL 패키징 + 매니페스트 생성
#   Wave F: Validate     — 예상 개선도 추정 + 리포트
#
# 출력: .agent/skq-{DATE}/ 폴더 내 각 Wave 결과물
# 적용: ship 명령어로 ship.sql 검토 후 실행

set -euo pipefail

SCOPE="${1:-전체 검색 키워드 품질 개선 — 검색 정확도 및 결과 노출 향상}"

# ── 날짜 / 실행 ID ────────────────────────────────────────────
RUN_DATE="$(date +%Y%m%d-%H%M%S)"
RUN_ID="skq-${RUN_DATE}"
FLAG_DIR=".agent/${RUN_ID}"
OUTPUT_DIR="docs/reports/${RUN_ID}"

mkdir -p "${FLAG_DIR}" "${OUTPUT_DIR}"

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
