# ── Wave 완료 게이트 함수 ─────────────────────────────────────
wait_wave() {
  local wave="$1"
  local flag_file="${FLAG_DIR}/wave_${wave}_done"
  local timeout=600
  local elapsed=0

  echo "     ⏳ Wave ${wave} 완료 대기..."
  while [[ ! -f "${flag_file}" ]]; do
    sleep 5
    elapsed=$((elapsed + 5))
    if [[ ${elapsed} -ge ${timeout} ]]; then
      echo "     ❌ Wave ${wave} 타임아웃 (${timeout}s). 종료합니다."
      exit 1
    fi
  done
  echo "     ✅ Wave ${wave} 완료"
}

