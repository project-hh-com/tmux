#!/usr/bin/env bash
# skq-setup — Search Keyword Quality 명령어 실행 환경 셋업
# 사용법: bash skq-setup
#
# 수행 작업:
#   1. DB 자격증명 확인 / 설정 (sq-setup과 공유)
#   2. psql 설치 확인 / Homebrew로 자동 설치
#   3. claude CLI 설치 확인
#   4. danble DB 연결 테스트
#   5. skq 명령어를 PATH에 등록 (심볼릭 링크)

set -euo pipefail

SKQ_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BIN_DIR="${HOME}/.local/bin"
SQ_DB_ENV="${HOME}/.config/sq/db.env"

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  🎯 skq 환경 셋업 (Search Keyword Quality)"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# ── Step 1: DB 자격증명 확인 / 설정 ──────────────────────────
echo "1/5  DB 자격증명 확인..."
mkdir -p "${HOME}/.config/sq"

SKIP_CREDENTIAL_INPUT=0

if [[ -f "${SQ_DB_ENV}" ]]; then
  echo "     ✅ 기존 자격증명 발견: ${SQ_DB_ENV}"
  echo "     (sq 명령어와 공유됩니다)"
  # shellcheck source=/dev/null
  source "${SQ_DB_ENV}"
  SKIP_CREDENTIAL_INPUT=1
else
  echo "     ⚠️  DB 자격증명 파일이 없습니다: ${SQ_DB_ENV}"
  echo "     sq-setup을 먼저 실행했다면 이미 있어야 합니다."
  echo ""
  read -r -p "     지금 직접 입력하시겠습니까? [y/N] " SETUP_NOW
  if [[ ! "${SETUP_NOW}" =~ ^[Yy]$ ]]; then
    echo "     ❌ DB 자격증명 없이는 skq를 실행할 수 없습니다."
    echo "        sq-setup을 먼저 실행하세요."
    exit 1
  fi
fi

if [[ "${SKIP_CREDENTIAL_INPUT}" != "1" ]]; then
  echo ""
  echo "     DB 접속 정보를 입력하세요 (Enter = 기본값 사용)"
  echo ""

  read -r -p "     PGHOST   [production-danble-v3-read-dms.cnxuazoc6fmf.ap-northeast-2.rds.amazonaws.com]: " INPUT_HOST
  PGHOST="${INPUT_HOST:-production-danble-v3-read-dms.cnxuazoc6fmf.ap-northeast-2.rds.amazonaws.com}"

  read -r -p "     PGDATABASE [danble]: " INPUT_DB
  PGDATABASE="${INPUT_DB:-danble}"

  read -r -p "     PGUSER   [danble_read_only]: " INPUT_USER
  PGUSER="${INPUT_USER:-danble_read_only}"

  read -r -s -p "     PGPASSWORD: " INPUT_PASS
  echo ""
  PGPASSWORD="${INPUT_PASS}"

  read -r -p "     PGPORT   [5432]: " INPUT_PORT
  PGPORT="${INPUT_PORT:-5432}"

  cat > "${SQ_DB_ENV}" << ENVEOF
# danble PostgreSQL read-only replica
# 생성: $(date)
# 이 파일은 git에 포함되지 않습니다 — 로컬 전용
# sq / skq 명령어가 함께 사용합니다
export PGHOST="${PGHOST}"
export PGDATABASE="${PGDATABASE}"
export PGUSER="${PGUSER}"
export PGPASSWORD="${PGPASSWORD}"
export PGPORT="${PGPORT}"
export PGSSLMODE="require"
ENVEOF

  chmod 600 "${SQ_DB_ENV}"
  echo "     ✅ 자격증명 저장 완료: ${SQ_DB_ENV} (chmod 600)"
fi

export PGHOST PGDATABASE PGUSER PGPASSWORD PGPORT
export PGSSLMODE="require"

# ── Step 2: psql 설치 확인 ────────────────────────────────────
echo ""
echo "2/5  psql 설치 확인..."
if command -v psql &> /dev/null; then
  PSQL_VERSION=$(psql --version 2>&1 | head -1)
  echo "     ✅ psql 이미 설치됨: ${PSQL_VERSION}"
else
  echo "     ⚠️  psql 미설치 — Homebrew로 설치 시도..."
  if command -v brew &> /dev/null; then
    echo "     brew install libpq 실행 중..."
    brew install libpq
    LIBPQ_BIN="$(brew --prefix libpq)/bin"
    if [[ ! ":$PATH:" == *":${LIBPQ_BIN}:"* ]]; then
      echo "" >> "${HOME}/.zshrc"
      echo "# libpq (psql) — skq-setup 추가" >> "${HOME}/.zshrc"
      echo "export PATH=\"${LIBPQ_BIN}:\$PATH\"" >> "${HOME}/.zshrc"
      export PATH="${LIBPQ_BIN}:${PATH}"
    fi
    if ! command -v psql &> /dev/null; then
      echo "     ❌ PATH 문제 — 터미널에서 직접 실행하세요:"
      echo "        export PATH=\"${LIBPQ_BIN}:\$PATH\""
      exit 1
    fi
    echo "     ✅ psql 설치 완료: $(psql --version | head -1)"
  else
    echo "     ❌ Homebrew 미설치. 수동 설치:"
    echo "        /bin/bash -c \"\$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)\""
    echo "        brew install libpq"
    exit 1
  fi
fi

# ── Step 3: claude CLI 설치 확인 ──────────────────────────────
echo ""
echo "3/5  claude CLI 설치 확인..."
if command -v claude &> /dev/null; then
  CLAUDE_VERSION=$(claude --version 2>&1 | head -1)
  echo "     ✅ claude CLI 이미 설치됨: ${CLAUDE_VERSION}"
else
  echo "     ❌ claude CLI 미설치"
  echo ""
  echo "     skq는 claude CLI가 필요합니다. 설치 방법:"
  echo "        npm install -g @anthropic-ai/claude-code"
  echo ""
  echo "     설치 후 다시 실행하세요: bash skq-setup"
  exit 1
fi

# ── Step 4: DB 연결 테스트 ────────────────────────────────────
echo ""
echo "4/5  danble DB 연결 테스트..."
DB_TEST=$(PGPASSWORD="${PGPASSWORD}" PGCONNECT_TIMEOUT=15 psql \
  -h "${PGHOST}" -U "${PGUSER}" -d "${PGDATABASE}" -p "${PGPORT}" \
  --no-password \
  -c "SELECT COUNT(*) FROM search_keywords LIMIT 1;" \
  -t 2>&1 || true)

if echo "${DB_TEST}" | grep -qE "^[[:space:]]*[0-9]+"; then
  COUNT=$(echo "${DB_TEST}" | tr -d '[:space:]')
  echo "     ✅ DB 연결 성공! (search_keywords: ${COUNT}건)"
  echo ""
  echo "     skq 관련 테이블 확인..."
  TABLES=(
    "search_keywords"
    "search_keyword_rankings"
    "search_keyword_relations"
    "search_brand_keywords"
    "search_category_keywords"
    "search_color_keywords"
  )
  for TABLE in "${TABLES[@]}"; do
    ROW_COUNT=$(PGPASSWORD="${PGPASSWORD}" psql \
      -h "${PGHOST}" -U "${PGUSER}" -d "${PGDATABASE}" -p "${PGPORT}" \
      --no-password --connect-timeout=10 \
      -c "SELECT COUNT(*) FROM ${TABLE};" -t 2>/dev/null | tr -d '[:space:]' || echo "오류")
    printf "     %-38s %s행\n" "${TABLE}" "${ROW_COUNT}"
  done
else
  echo "     ❌ DB 연결 실패 — VPN/네트워크 확인 후 재시도"
  echo "     ${DB_TEST}"
  echo ""
  echo "     자격증명 재설정: rm ${SQ_DB_ENV} && bash skq-setup"
  exit 1
fi

# ── Step 5: skq 명령어 PATH 등록 ─────────────────────────────
echo ""
echo "5/5  skq 명령어 PATH 등록..."
mkdir -p "${BIN_DIR}"

SKQ_SCRIPT="${SKQ_DIR}/skq"
SKQ_LINK="${BIN_DIR}/skq"

if [[ ! -f "${SKQ_SCRIPT}" ]]; then
  echo "     ❌ skq 스크립트 없음: ${SKQ_SCRIPT}"
  exit 1
fi

chmod +x "${SKQ_SCRIPT}"
[[ -L "${SKQ_LINK}" ]] && rm "${SKQ_LINK}"
ln -s "${SKQ_SCRIPT}" "${SKQ_LINK}"
echo "     ✅ skq: ${SKQ_LINK} → ${SKQ_SCRIPT}"

if [[ ! ":$PATH:" == *":${BIN_DIR}:"* ]]; then
  echo "" >> "${HOME}/.zshrc"
  echo "# skq (Search Keyword Quality) PATH — skq-setup 추가" >> "${HOME}/.zshrc"
  echo "export PATH=\"${BIN_DIR}:\$PATH\"" >> "${HOME}/.zshrc"
  echo "     ~/.zshrc 에 PATH 추가됨 → source ~/.zshrc 실행 필요"
else
  echo "     ✅ ${BIN_DIR} 이미 PATH에 있음"
fi

# ── 완료 ─────────────────────────────────────────────────────
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  ✅ skq 환경 셋업 완료!"
echo ""
echo "  사용법:"
echo "    skq              # 전체 키워드 품질 개선 (6-Phase)"
echo "    skq \"브랜드 범위\" # 범위 지정 실행"
echo ""
echo "  워크플로:"
echo "    1. skq           (분석 + SQL 생성 → docs/reports/)"
echo "    2. SQL 검토 후 적용"
echo "    3. skq           (재측정 → 개선도 확인)"
echo ""
echo "  문서:"
echo "    skq-overview.html        # 전체 워크플로 시각화"
echo "    docs/search-pipeline.md  # 검색 파이프라인 구조"
echo "    docs/db-schema.md        # DB 스키마 상세"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
