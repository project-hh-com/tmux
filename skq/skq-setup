#!/usr/bin/env bash
# skq-setup — SKQ(Search Keyword Quality) 명령어 실행 환경 셋업
# 사용법: bash skq-setup
#
# 수행 작업:
#   1. DB 자격증명은 sq-setup과 공유 (~/.config/sq/db.env)
#   2. skq, ship 명령어를 PATH에 등록 (심볼릭 링크)
#   3. 연결 테스트 (기존 설정 재사용)

set -euo pipefail

SKQ_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BIN_DIR="${HOME}/.local/bin"
SQ_DB_ENV="${HOME}/.config/sq/db.env"

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  🔍 skq 환경 셋업 (Search Keyword Quality)"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# ── Step 1: DB 자격증명 확인 ──────────────────────────────────
echo "1/3  DB 자격증명 확인..."

if [[ -f "${SQ_DB_ENV}" ]]; then
  echo "     ✅ 기존 sq 자격증명 발견: ${SQ_DB_ENV}"
  # shellcheck source=/dev/null
  source "${SQ_DB_ENV}"
else
  echo "     ⚠️  DB 자격증명 파일이 없습니다: ${SQ_DB_ENV}"
  echo "     sq-setup을 먼저 실행하거나, 지금 직접 입력하세요."
  echo ""
  read -r -p "     지금 입력하시겠습니까? [y/N] " SETUP_NOW
  if [[ "${SETUP_NOW}" =~ ^[Yy]$ ]]; then
    # sq-setup이 같은 tmux 프로젝트 내 sq/ 폴더에 있다고 가정
    SQ_SETUP="${HOME}/development/tmux/sq/sq-setup"
    if [[ -f "${SQ_SETUP}" ]]; then
      bash "${SQ_SETUP}"
    else
      echo "     ❌ sq-setup을 찾을 수 없습니다: ${SQ_SETUP}"
      echo "        sq-setup을 직접 실행하세요."
      exit 1
    fi
    source "${SQ_DB_ENV}"
  else
    echo "     ❌ DB 자격증명 없이는 skq를 실행할 수 없습니다."
    exit 1
  fi
fi

# ── Step 2: DB 연결 테스트 ────────────────────────────────────
echo ""
echo "2/3  danble DB 연결 테스트..."
DB_TEST=$(PGPASSWORD="${PGPASSWORD}" PGCONNECT_TIMEOUT=15 psql \
  -h "${PGHOST}" -U "${PGUSER}" -d "${PGDATABASE}" -p "${PGPORT}" \
  --no-password \
  -c "SELECT COUNT(*) FROM search_keywords LIMIT 1;" \
  -t 2>&1 || true)

if echo "${DB_TEST}" | grep -qE "^[[:space:]]*[0-9]+"; then
  COUNT=$(echo "${DB_TEST}" | tr -d '[:space:]')
  echo "     ✅ DB 연결 성공! (search_keywords: ${COUNT}건)"
else
  echo "     ❌ DB 연결 실패 — VPN/네트워크 확인 후 재시도"
  echo "     ${DB_TEST}"
  exit 1
fi

# ── Step 3: skq, ship PATH 등록 ──────────────────────────────
echo ""
echo "3/3  skq 명령어 PATH 등록..."
mkdir -p "${BIN_DIR}"

# skq
SKQ_SCRIPT="${SKQ_DIR}/skq"
SKQ_LINK="${BIN_DIR}/skq"
if [[ ! -f "${SKQ_SCRIPT}" ]]; then
  echo "     ❌ skq 스크립트 없음: ${SKQ_SCRIPT}"
  exit 1
fi
chmod +x "${SKQ_SCRIPT}"
[[ -L "${SKQ_LINK}" ]] && rm "${SKQ_LINK}"
ln -s "${SKQ_SCRIPT}" "${SKQ_LINK}"
echo "     ✅ skq:  ${SKQ_LINK} → ${SKQ_SCRIPT}"

# ship
SHIP_SCRIPT="${SKQ_DIR}/ship"
SHIP_LINK="${BIN_DIR}/ship"
if [[ ! -f "${SHIP_SCRIPT}" ]]; then
  echo "     ❌ ship 스크립트 없음: ${SHIP_SCRIPT}"
  exit 1
fi
chmod +x "${SHIP_SCRIPT}"
[[ -L "${SHIP_LINK}" ]] && rm "${SHIP_LINK}"
ln -s "${SHIP_SCRIPT}" "${SHIP_LINK}"
echo "     ✅ ship: ${SHIP_LINK} → ${SHIP_SCRIPT}"

# PATH 등록 확인
if [[ ! ":$PATH:" == *":${BIN_DIR}:"* ]]; then
  echo "" >> "${HOME}/.zshrc"
  echo "# skq PATH — skq-setup 추가" >> "${HOME}/.zshrc"
  echo "export PATH=\"${BIN_DIR}:\$PATH\"" >> "${HOME}/.zshrc"
  echo "     ~/.zshrc 에 PATH 추가됨 → source ~/.zshrc 실행 필요"
else
  echo "     ✅ ${BIN_DIR} 이미 PATH에 있음"
fi

# ── 완료 ─────────────────────────────────────────────────────
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  ✅ skq 환경 셋업 완료!"
echo ""
echo "  사용법:"
echo "    skq              # 검색 키워드 품질 개선 (6-Wave)"
echo "    skq \"특정 범위\"  # 범위 지정 실행"
echo "    ship             # 생성된 SQL 적용"
echo ""
echo "  워크플로:"
echo "    1. skq           (키워드 품질 분석 + SQL 생성)"
echo "    2. ship          (생성된 SQL 검토 후 적용)"
echo "    3. skq           (재측정 → 개선도 확인)"
echo ""
echo "  문서:"
echo "    docs/search-pipeline.md  # 검색 파이프라인 구조"
echo "    docs/db-schema.md        # DB 스키마 상세"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
