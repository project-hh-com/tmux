#!/usr/bin/env bash
# ship — SKQ 결과 SQL 적용 명령어
# 사용법: ship              → 최신 skq 결과 적용
#         ship {RUN_ID}    → 특정 실행 결과 적용 (예: ship skq-20260504-153000)
#         ship --dry-run   → SQL 출력만, 실제 적용 안 함
#         ship --list      → 적용 가능한 결과 목록 조회
#
# ⚠️  주의: 이 명령어는 danble DB에 직접 쓰기 작업을 수행합니다.
#           ship.sql을 반드시 검토한 후 실행하세요.

set -euo pipefail

SKQ_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ── 인자 파싱 ────────────────────────────────────────────────
DRY_RUN=false
LIST_MODE=false
TARGET_RUN_ID=""

for arg in "$@"; do
  case "${arg}" in
    --dry-run) DRY_RUN=true ;;
    --list)    LIST_MODE=true ;;
    skq-*)     TARGET_RUN_ID="${arg}" ;;
    *)
      echo "❌ 알 수 없는 인자: ${arg}"
      echo "   사용법: ship [--dry-run] [--list] [RUN_ID]"
      exit 1
      ;;
  esac
done

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  🚀 SKQ Ship — SQL 적용"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# ── --list 모드 ───────────────────────────────────────────────
if [[ "${LIST_MODE}" == "true" ]]; then
  echo ""
  echo "  적용 가능한 SKQ 결과 목록:"
  echo ""
  REPORTS_DIR="${SKQ_DIR}/docs/reports"
  if [[ ! -d "${REPORTS_DIR}" ]]; then
    echo "  (결과 없음 — skq를 먼저 실행하세요)"
    exit 0
  fi

  found=0
  for run_dir in "${REPORTS_DIR}"/skq-*/; do
    [[ -d "${run_dir}" ]] || continue
    run_id="$(basename "${run_dir}")"
    sql_file="${run_dir}/ship.sql"
    manifest="${run_dir}/ship-manifest.md"

    if [[ -f "${sql_file}" ]]; then
      sql_lines=$(wc -l < "${sql_file}" | tr -d ' ')
      manifest_exists="✅"
      [[ -f "${manifest}" ]] || manifest_exists="⚠️ "
      echo "    ${manifest_exists} ${run_id}  (${sql_lines}줄)"
      found=$((found + 1))
    fi
  done

  [[ ${found} -eq 0 ]] && echo "  (ship.sql 있는 결과 없음)"
  exit 0
fi

# ── DB 자격증명 (쓰기 계정 필요) ─────────────────────────────
SQ_DB_ENV="${HOME}/.config/sq/db.env"
if [[ -f "${SQ_DB_ENV}" ]]; then
  # shellcheck source=/dev/null
  source "${SQ_DB_ENV}"
else
  echo "❌ DB 자격증명 파일이 없습니다: ${SQ_DB_ENV}"
  echo "   skq-setup을 먼저 실행하세요."
  exit 1
fi

# ship은 쓰기 계정 필요 — PGWRITE_USER/PGWRITE_PASSWORD가 있으면 우선 사용
SHIP_HOST="${PGHOST}"
SHIP_DB="${PGDATABASE:-danble}"
SHIP_USER="${PGWRITE_USER:-${PGUSER}}"
SHIP_PASSWORD="${PGWRITE_PASSWORD:-${PGPASSWORD}}"
SHIP_PORT="${PGPORT:-5432}"

# ── 대상 RUN_ID 결정 ─────────────────────────────────────────
REPORTS_DIR="${SKQ_DIR}/docs/reports"

if [[ -z "${TARGET_RUN_ID}" ]]; then
  # 최신 결과 자동 선택
  TARGET_RUN_ID="$(ls -1t "${REPORTS_DIR}" 2>/dev/null | grep '^skq-' | head -1 || true)"
  if [[ -z "${TARGET_RUN_ID}" ]]; then
    echo "❌ 적용할 SKQ 결과가 없습니다."
    echo "   skq를 먼저 실행하세요."
    exit 1
  fi
  echo "  자동 선택: ${TARGET_RUN_ID}"
fi

TARGET_DIR="${REPORTS_DIR}/${TARGET_RUN_ID}"
SQL_FILE="${TARGET_DIR}/ship.sql"
MANIFEST_FILE="${TARGET_DIR}/ship-manifest.md"

if [[ ! -f "${SQL_FILE}" ]]; then
  echo "❌ ship.sql 없음: ${SQL_FILE}"
  echo "   지정한 RUN_ID를 확인하거나 skq를 다시 실행하세요."
  exit 1
fi

# ── ship.sql 미리보기 ─────────────────────────────────────────
echo ""
echo "  📄 ship.sql: ${SQL_FILE}"
echo "  $(wc -l < "${SQL_FILE}") 줄"
echo ""

if [[ -f "${MANIFEST_FILE}" ]]; then
  echo "  변경 요약:"
  # 테이블 부분만 출력
  awk '/^## 변경 요약/,/^## /' "${MANIFEST_FILE}" | head -20
  echo ""
fi

# ── dry-run 모드 ─────────────────────────────────────────────
if [[ "${DRY_RUN}" == "true" ]]; then
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "  [DRY-RUN] SQL 내용 (실제 적용 안 함):"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  cat "${SQL_FILE}"
  exit 0
fi

# ── 실행 확인 ────────────────────────────────────────────────
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  ⚠️  danble DB에 직접 쓰기 작업을 수행합니다."
echo "  HOST: ${SHIP_HOST}"
echo "  DB:   ${SHIP_DB}"
echo "  USER: ${SHIP_USER}"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
echo "  ship.sql을 검토했습니까? 계속하려면 'ship'을 입력하세요."
echo -n "  > "
read -r CONFIRM

if [[ "${CONFIRM}" != "ship" ]]; then
  echo "  취소됨."
  exit 0
fi

# ── SQL 실행 ─────────────────────────────────────────────────
echo ""
echo "  🔄 SQL 실행 중..."

EXEC_LOG="${TARGET_DIR}/ship-exec-$(date +%Y%m%d-%H%M%S).log"

PGPASSWORD="${SHIP_PASSWORD}" psql \
  -h "${SHIP_HOST}" \
  -U "${SHIP_USER}" \
  -d "${SHIP_DB}" \
  -p "${SHIP_PORT}" \
  --no-password \
  -f "${SQL_FILE}" \
  -v ON_ERROR_STOP=1 \
  2>&1 | tee "${EXEC_LOG}"

EXIT_CODE="${PIPESTATUS[0]}"

if [[ "${EXIT_CODE}" -eq 0 ]]; then
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "  ✅ SQL 적용 완료!"
  echo "  실행 ID: ${TARGET_RUN_ID}"
  echo "  로그:    ${EXEC_LOG}"
  echo ""
  echo "  개선 효과 확인:"
  echo "    cat ${TARGET_DIR}/wave-f-validate.md"
  echo ""
  echo "  재측정:"
  echo "    sq-v2    # 품질 점수 재측정"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
else
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "  ❌ SQL 실행 실패 (exit: ${EXIT_CODE})"
  echo "  로그: ${EXEC_LOG}"
  echo ""
  echo "  트랜잭션이 자동 롤백되었습니다."
  echo "  ship.sql을 확인하고 수정 후 재시도하세요."
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  exit 1
fi
