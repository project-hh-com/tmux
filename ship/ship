#!/usr/bin/env bash
# ship — Claude Agent Teams 워크플로 (동적 에이전트 선택)
# 사용법: ship "기능/이슈 설명"

set -euo pipefail

FEATURE="${1:-}"
if [[ -z "$FEATURE" ]]; then
  echo "사용법: ship \"기능 설명\""
  exit 1
fi

# ── 토론 함수 (Red → Blue → Judge, 최대 2라운드) ────────────
# 모든 대용량 파일은 경로만 전달 — 에이전트가 Read 툴로 직접 읽음
run_debate() {
  local TOPIC="$1"
  local CONTEXT_FILE="$2"
  local FOCUS="$3"          # plan | test | review
  local ALLOW_REWORK="${4:-0}"  # 1이면 REWORK 판정 허용
  local MAX_ROUNDS=2
  local ROUND=0
  local VERDICT="CONTINUE"

  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "  🗣️  토론: ${TOPIC}"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

  while [[ $ROUND -lt $MAX_ROUNDS ]] && [[ "$VERDICT" != "CONSENSUS" ]]; do
    ROUND=$((ROUND + 1))
    echo ""
    echo "  🔴 Round ${ROUND}/${MAX_ROUNDS} — Red 공격 중..."

    cat > "${FLAG_DIR}/red_${FOCUS}_${ROUND}.txt" << REDEOF
당신은 red 에이전트입니다. 아래 파일의 허점, 위험요소, 누락된 엣지케이스를 공격하세요.
해결책 제시 금지. 문제 지적만 하세요.

주제: ${TOPIC}
원본 작업: ${FEATURE}

검토 대상 파일 (Read 툴로 직접 읽으세요): ${CONTEXT_FILE}

공격 내용을 ${FLAG_DIR}/red_${FOCUS}_${ROUND}.md 에 저장하세요.
REDEOF
    claude -p "$(cat "${FLAG_DIR}/red_${FOCUS}_${ROUND}.txt")" \
      --allowedTools "Read,Write,Glob,Grep" --dangerously-skip-permissions 2>&1 | tee "${FLAG_DIR}/red_${FOCUS}_${ROUND}.log"

    echo "  🔵 Round ${ROUND}/${MAX_ROUNDS} — Blue 방어 중..."
    cat > "${FLAG_DIR}/blue_${FOCUS}_${ROUND}.txt" << BLUEEOF
당신은 blue 에이전트입니다. Red의 공격을 검토하고 각 항목을 ACCEPT/MITIGATE/REJECT로 판정하세요.
ACCEPT 또는 MITIGATE 항목은 실제로 파일을 수정해 반영하세요.

주제: ${TOPIC}
원본 작업: ${FEATURE}

검토 대상 파일 (Read 툴로 읽으세요): ${CONTEXT_FILE}
Red 공격 파일 (Read 툴로 읽으세요): ${FLAG_DIR}/red_${FOCUS}_${ROUND}.md

판정 및 수정 결과를 ${FLAG_DIR}/blue_${FOCUS}_${ROUND}.md 에 저장하세요.
BLUEEOF
    claude -p "$(cat "${FLAG_DIR}/blue_${FOCUS}_${ROUND}.txt")" \
      --allowedTools "Read,Write,Edit,Glob,Grep" --dangerously-skip-permissions 2>&1 | tee "${FLAG_DIR}/blue_${FOCUS}_${ROUND}.log"

    echo "  ⚖️  Round ${ROUND}/${MAX_ROUNDS} — Judge 판정 중..."
    cat > "${FLAG_DIR}/judge_${FOCUS}_${ROUND}.txt" << JUDGEEOF
당신은 judge 에이전트입니다. Red/Blue 토론을 심판하세요.

주제: ${TOPIC}
라운드: ${ROUND}/${MAX_ROUNDS}

Red 공격 파일 (Read 툴로 읽으세요): ${FLAG_DIR}/red_${FOCUS}_${ROUND}.md
Blue 방어 파일 (Read 툴로 읽으세요): ${FLAG_DIR}/blue_${FOCUS}_${ROUND}.md

판정 결과를 ${FLAG_DIR}/judge_${FOCUS}_${ROUND}.md 에 저장하고,
첫 번째 줄에 반드시 다음 형식으로 작성하세요:
VERDICT: CONSENSUS   (Blue가 충분히 방어/개선함 — 종료)
VERDICT: CONTINUE    (사소한 문제 — 다음 라운드에서 Blue가 수정)
$(if [[ "$ALLOW_REWORK" == "1" ]]; then echo "VERDICT: REWORK      (근본적 재구현 필요 — Wave 에이전트를 처음부터 다시 실행해야 함)"; fi)
JUDGEEOF
    claude -p "$(cat "${FLAG_DIR}/judge_${FOCUS}_${ROUND}.txt")" \
      --allowedTools "Read,Write,Edit" --dangerously-skip-permissions 2>&1 | tee "${FLAG_DIR}/judge_${FOCUS}_${ROUND}.log"

    VERDICT=$(grep "^VERDICT:" "${FLAG_DIR}/judge_${FOCUS}_${ROUND}.md" 2>/dev/null | head -1 | awk '{print $2}')
    VERDICT="${VERDICT:-CONTINUE}"
    echo "  ⚖️  판정: ${VERDICT}"
    # REWORK는 루프를 즉시 탈출 (다음 라운드 없이 Wave 재실행)
    [[ "$VERDICT" == "REWORK" ]] && break
  done

  echo ""
  case "$VERDICT" in
    CONSENSUS) echo "  ✅ CONSENSUS — 다음 단계로 진행" ;;
    REWORK)    echo "  🔄 REWORK — Wave 에이전트 재실행 필요" ;;
    *)         echo "  ⚠️  ${MAX_ROUNDS}라운드 종료 — 최선의 결과로 진행" ;;
  esac
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""

  # 최종 verdict를 파일로 저장 (호출부에서 REWORK 여부 확인용)
  echo "$VERDICT" > "${FLAG_DIR}/debate_${FOCUS}_verdict.txt"
}

# ── 웨이브 대기 함수 ─────────────────────────────────────────
# 형식: wait_wave <wave_file> <label>
# wave_file 행 형식: AGENT_NAME|EMOJI|SCRIPT_PATH
wait_wave() {
  local WAVE_FILE="$1"
  local WAVE_LABEL="$2"
  local WAVE_COUNT=0
  local WAIT_COUNT=0
  local MAX_WAIT=600

  [[ ! -s "$WAVE_FILE" ]] && return

  while IFS='|' read -r AGENT_NAME AGENT_EMOJI AGENT_SCRIPT; do
    WAVE_COUNT=$((WAVE_COUNT + 1))
  done < "$WAVE_FILE"

  while [[ $WAIT_COUNT -lt $MAX_WAIT ]]; do
    local DONE_COUNT=0
    while IFS='|' read -r AGENT_NAME AGENT_EMOJI AGENT_SCRIPT; do
      [[ -f "${FLAG_DIR}/${AGENT_NAME}.done" ]] && DONE_COUNT=$((DONE_COUNT + 1)) || true
    done < "$WAVE_FILE"
    [[ $DONE_COUNT -ge $WAVE_COUNT ]] && break
    printf "\r  ⏳ %s 완료: %d/%d  (%ds)   " "$WAVE_LABEL" "$DONE_COUNT" "$WAVE_COUNT" "$WAIT_COUNT"
    sleep 5
    WAIT_COUNT=$((WAIT_COUNT + 5))
  done
  echo ""
}

# ── 완료된 웨이브 패널/세션 정리 ─────────────────────────────
# 전역 변수 사용: PANE_ID_FILE, FLAG_DIR, TMUX, MAIN_PANE
cleanup_wave() {
  # tmux 패널 정리
  if [[ -n "${TMUX:-}" ]] && [[ -s "$PANE_ID_FILE" ]]; then
    while IFS= read -r PANE_ID; do
      tmux kill-pane -t "$PANE_ID" 2>/dev/null || true
    done < "$PANE_ID_FILE"
    > "$PANE_ID_FILE"
    tmux select-pane -t "$MAIN_PANE" 2>/dev/null || true
  fi
  # 백그라운드 세션 정리
  if [[ -f "${FLAG_DIR}/agent_sessions.txt" ]] && [[ -s "${FLAG_DIR}/agent_sessions.txt" ]]; then
    while IFS= read -r SESSION; do
      tmux kill-session -t "$SESSION" 2>/dev/null || true
    done < "${FLAG_DIR}/agent_sessions.txt"
    > "${FLAG_DIR}/agent_sessions.txt"
  fi
}

# ── tmux 웨이브 실행 함수 ────────────────────────────────────
# 레이아웃: [Plan] | [Wave A 에이전트 세로] | [Wave B 에이전트 세로]
# - 각 웨이브는 이전 웨이브 오른쪽에 가로로 붙음
# - 웨이브 내부는 세로로 분할
# 전역 변수 사용: MAIN_WIN, MAIN_PANE, CWD, PANE_ID_FILE, LAST_WAVE_ANCHOR_PANE
LAST_WAVE_ANCHOR_PANE=""

launch_wave_tmux() {
  local WAVE_FILE="$1"
  local WAVE_LABEL="$2"
  local WAVE_COUNT=0

  [[ ! -s "$WAVE_FILE" ]] && return

  while IFS='|' read -r AGENT_NAME AGENT_EMOJI AGENT_SCRIPT; do
    WAVE_COUNT=$((WAVE_COUNT + 1))
  done < "$WAVE_FILE"

  echo "  ▶ ${WAVE_LABEL} (${WAVE_COUNT}개) 시작..."

  local FIRST_AGENT_PANE=""
  local FIRST=1

  while IFS='|' read -r AGENT_NAME AGENT_EMOJI AGENT_SCRIPT; do
    local NEW_PANE
    if [[ $FIRST -eq 1 ]]; then
      if [[ -z "$LAST_WAVE_ANCHOR_PANE" ]]; then
        # 첫 웨이브: 메인 패널 오른쪽에 가로 분할
        tmux split-window -h -t "$MAIN_WIN" -c "$CWD"
      else
        # 이후 웨이브: 이전 웨이브 첫 패널 오른쪽에 가로 분할 (새 컬럼)
        tmux split-window -h -t "$LAST_WAVE_ANCHOR_PANE" -c "$CWD"
      fi
      NEW_PANE=$(tmux display-message -p '#{pane_id}')
      FIRST_AGENT_PANE="$NEW_PANE"
      FIRST=0
    else
      # 같은 웨이브 내: 첫 패널 기준 세로 분할
      NEW_PANE=$(tmux split-window -v -t "$FIRST_AGENT_PANE" -c "$CWD" -P -F '#{pane_id}')
    fi
    echo "$NEW_PANE" >> "$PANE_ID_FILE"
    tmux select-pane -t "$NEW_PANE" -T "${AGENT_EMOJI} ${AGENT_NAME}"
    tmux send-keys -t "$NEW_PANE" "bash '${AGENT_SCRIPT}'" Enter
  done < "$WAVE_FILE"

  # 이 웨이브의 앵커 저장 → 다음 웨이브가 오른쪽에 붙을 기준점
  LAST_WAVE_ANCHOR_PANE="$FIRST_AGENT_PANE"

  # main-vertical: Plan 왼쪽, 나머지 오른쪽에 균등 세로 배치
  tmux select-layout -t "$MAIN_WIN" main-vertical
  tmux select-pane -t "$MAIN_PANE"
}

# ─────────────────────────────────────────────────────────────

TIMESTAMP=$(date +%Y%m%d-%H%M%S)
FLAG_DIR=".agent/ship-${TIMESTAMP}"
mkdir -p "$FLAG_DIR"

# ── 브랜치 생성 ─────────────────────────────────────────────
# Feature 설명에서 ASCII 영숫자만 추출해 슬러그로 사용
BRANCH_SLUG=$(printf '%s' "$FEATURE" | LC_ALL=C tr -dc 'a-zA-Z0-9 ' | tr ' ' '-' | \
              tr '[:upper:]' '[:lower:]' | sed 's/--*/-/g' | sed 's/^-\|-$//g' | cut -c1-40)
[[ -z "$BRANCH_SLUG" ]] && BRANCH_SLUG="feature"
BRANCH_NAME="feat/${BRANCH_SLUG}-${TIMESTAMP}"

# 현재 브랜치 확인 — 보호 브랜치면 새 브랜치 생성, 아니면 현재 브랜치 사용
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
if [[ "$CURRENT_BRANCH" =~ ^(main|master|prd|develop)$ ]]; then
  git checkout -b "$BRANCH_NAME" 2>&1 | tee -a "${FLAG_DIR}/git.log"
  git push -u origin "$BRANCH_NAME" 2>&1 | tee -a "${FLAG_DIR}/git.log" || true
  echo "  🌿 새 브랜치 생성: $BRANCH_NAME"
else
  BRANCH_NAME="$CURRENT_BRANCH"
  echo "  🌿 현재 브랜치 사용: $BRANCH_NAME"
fi

# ── 중간 커밋/푸시 헬퍼 ─────────────────────────────────────
# Architect가 생성한 commit_msg.txt 가 있으면 그 내용 사용.
# 없으면 FEATURE 원문 사용.
# 호출: auto_commit "feat" "구현" 또는 auto_commit "feat" "검증"
auto_commit() {
  local PREFIX="$1"
  local PHASE="${2:-}"   # Wave 단계 (구현/검증 등), 없으면 생략
  local CLEAN_MSG
  if [[ -f "${FLAG_DIR}/commit_msg.txt" ]]; then
    CLEAN_MSG=$(head -1 "${FLAG_DIR}/commit_msg.txt" | tr -d '\r\n')
  else
    CLEAN_MSG="$FEATURE"
  fi
  local FULL_MSG="${PREFIX}: ${CLEAN_MSG}"
  [[ -n "$PHASE" ]] && FULL_MSG="${FULL_MSG} — ${PHASE}"
  git add -A 2>/dev/null || true
  if git diff --cached --quiet 2>/dev/null; then
    echo "  ⏭️  변경사항 없음 — 커밋 스킵"
    return 0
  fi
  git commit -m "${FULL_MSG}

Co-Authored-By: Claude Sonnet 4.6 <noreply@anthropic.com>" 2>&1 | tee -a "${FLAG_DIR}/git.log" || true
  git push origin "$BRANCH_NAME" 2>&1 | tee -a "${FLAG_DIR}/git.log" || true
  echo "  ✅ 커밋/푸시 완료"
}

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  🚢 ship: \"$FEATURE\""
echo "  🌿 브랜치: $BRANCH_NAME"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

echo "📋 Phase 1: 설계 검토 및 에이전트 선택..."
echo ""

cat > "${FLAG_DIR}/architect_prompt.txt" << PROMPTEOF
당신은 architect입니다. 요청: "${FEATURE}"

세 가지를 수행하세요.

[1] 구현/수정 계획을 ${FLAG_DIR}/plan.md 에 저장하세요. (무엇을 왜 어떻게, 위험요소와 방어책 포함)

[2] 이 요청에 필요한 에이전트를 ${FLAG_DIR}/agents.txt 에 저장하세요.

[3] 이 요청을 git 커밋 메시지용 한 줄 요약으로 ${FLAG_DIR}/commit_msg.txt 에 저장하세요.
규칙:
- URL(@https://... 등) 제외
- 도구 지시사항("mcp사용해줘", "피그마 mcp" 등) 제외
- 60자 이내
- feat:/fix: 등 prefix 제외 (ship이 자동으로 붙임)
- 어떤 파일/페이지를 어떻게 바꿨는지 명확하게
예시:
  /login_phone 페이지 피그마 기준 스타일 최신화
  결제 완료 화면 구현 및 API 연동
  로그인 시 이름/전화번호 저장 버그 수정
형식(파이프 구분): 에이전트이름|이 요청에서 맡을 구체적 역할
예:
debugger|flarelane 로그인에서 이름/전화번호 저장 실패 원인 분석
backend|누락된 필드 저장 로직 수정

선택 가능 에이전트:
- backend  : API, 서비스 레이어, DB, Zod 검증
- frontend : React 컴포넌트, TanStack Query, Tailwind
- test     : 단위/통합 테스트, 커버리지 80%
- debugger : 버그 원인 분석, 재현, 가설 검증
- reviewer : 코드 리뷰, 타입 안전성, 레이어 규칙
- security : 보안, 인증/인가, 시크릿 관리

판단 기준:
- 버그/이슈 → debugger 반드시 포함
- API/로직 변경 → backend
- UI 변경 → frontend
- 새 코드 추가 → test
- 리뷰 요청 → reviewer
- 보안 관련 → security
불필요한 에이전트는 포함하지 마세요.

완료 후: touch ${FLAG_DIR}/architect.done
PROMPTEOF

claude -p "$(cat "${FLAG_DIR}/architect_prompt.txt")" --allowedTools "Read,Write,Edit,Bash,Glob,Grep" --dangerously-skip-permissions 2>&1 | tee "${FLAG_DIR}/architect.log"

echo ""
echo "✅ Phase 1 완료"

if [[ -f "${FLAG_DIR}/plan.md" ]]; then
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "📄 구현 계획: ${FLAG_DIR}/plan.md"
  cat "${FLAG_DIR}/plan.md"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
fi

# ── Debate 1: 설계 계획 토론 ────────────────────────────────
echo "🗣️  Debate 1: 설계 계획 검토 토론"
run_debate "설계 계획 검토 — 허점/위험요소 발굴" "${FLAG_DIR}/plan.md" "plan"

if [[ ! -f "${FLAG_DIR}/agents.txt" ]]; then
  echo "⚠️  agents.txt 없음 — 기본값 사용"
  printf 'backend|백엔드 구현\nfrontend|프론트엔드 구현\ntest|테스트 작성\n' > "${FLAG_DIR}/agents.txt"
fi

grep -v '^\s*$' "${FLAG_DIR}/agents.txt" > "${FLAG_DIR}/agents_clean.txt" || true
mv "${FLAG_DIR}/agents_clean.txt" "${FLAG_DIR}/agents.txt"

echo ""
echo "📋 선택된 에이전트:"
while IFS='|' read -r aname atask; do
  echo "   • ${aname}: ${atask}"
done < "${FLAG_DIR}/agents.txt"

echo ""
echo "⏩ 자동 승인 → Phase 3 시작"
echo ""
echo "🔨 Phase 3: 에이전트 2-웨이브 실행"
echo "   Wave A (구현): backend · frontend · debugger"
echo "   Wave B (검증): reviewer · test · security  ← Wave A 완료 후 시작"
echo ""

CWD=$(pwd)

# ── 에이전트 스크립트 생성 + 웨이브 분류 ───────────────────
> "${FLAG_DIR}/agents_wave_a.txt"   # 구현: backend, frontend, debugger
> "${FLAG_DIR}/agents_wave_b.txt"   # 검증: reviewer, test, security

IDX=0
while IFS='|' read -r AGENT_NAME AGENT_TASK; do
  DONE_FILE="${FLAG_DIR}/${AGENT_NAME}.done"
  AGENT_SCRIPT="${FLAG_DIR}/run_${IDX}_${AGENT_NAME}.sh"

  case "$AGENT_NAME" in
    backend)  ROLE="당신은 backend 에이전트입니다. API Route Handler, 서비스 레이어, Zod 검증 구현. services/→types/ 단방향 import만 허용." ;;
    frontend) ROLE="당신은 frontend 에이전트입니다. React 컴포넌트(PascalCase.tsx), TanStack Query, Tailwind CSS 구현." ;;
    test)     ROLE="당신은 test 에이전트입니다. Vitest + Testing Library 단위/통합 테스트. 커버리지 80% 이상. Wave A(구현) 완료 후 실행되므로 현재 코드베이스를 기준으로 테스트를 작성하세요." ;;
    debugger) ROLE="당신은 debugger 에이전트입니다. 경쟁 가설 방식으로 버그 원인 분석 후 수정. 재현 단계 먼저 확인." ;;
