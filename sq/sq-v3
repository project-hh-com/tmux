Python 배치 처리 예시 (v2와 동일):
```python
import urllib.request, urllib.parse, urllib.error, json, time, os

def fetch_with_retry(url, kw, max_retry=3):
    delays = [1, 2, 4]
    for attempt in range(max_retry):
        try:
            res = json.loads(urllib.request.urlopen(url, timeout=10).read())
            data = res.get('data', {})
            items = data.get('items', [])
            rq = data.get('result_query', {})
            return {
                'keyword': kw,
                'result_count': len(items),
                'total_count': data.get('total_count', 0),
                'product_ids': [x.get('product_display_id') for x in items],
                'brands': [x.get('brand', {}).get('label', '') for x in items],
                'brands_kor': [x.get('brand', {}).get('label_kor', '') for x in items],
                'extracted_brands': rq.get('extracted_brands', []),
                'extracted_colors': rq.get('extracted_colors', []),
                'extracted_categories': rq.get('extracted_categories', []),
                'remaining_keyword': rq.get('remaining_keyword', ''),
                'error': None
            }, None
        except urllib.error.HTTPError as e:
            if e.code == 429:
                time.sleep(delays[min(attempt, len(delays)-1)] * 3)
            elif e.code >= 500:
                time.sleep(delays[min(attempt, len(delays)-1)])
            else:
                return None, f'HTTP_{e.code}'
        except Exception as e:
            time.sleep(delays[min(attempt, len(delays)-1)])
            return None, f'ERR:{e}'
    return None, 'MAX_RETRY'
