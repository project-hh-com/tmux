SCORED_COUNT_F=$(python3 -c "import json,os; d=json.load(open('${FLAG_DIR}/scores.json')) if os.path.exists('${FLAG_DIR}/scores.json') else []; print(len(d))" 2>/dev/null || echo "0")
FIXABLE_F=$(python3 -c "import json,os; d=json.load(open('${FLAG_DIR}/scores.json')) if os.path.exists('${FLAG_DIR}/scores.json') else []; print(sum(1 for x in d if x.get('fixable')))" 2>/dev/null || echo "?")
GATE_LABEL="✅ 통과"
$GATE_PASS || GATE_LABEL="❌ 실패"
SQL_EXISTS="없음"
[[ -f "${FLAG_DIR}/fix_search_keywords.sql" ]] && SQL_EXISTS="${FLAG_DIR}/fix_search_keywords.sql"

cat > "${SUMMARY_FILE}" << SUMEOF
# sq-v3 실행 요약

| 항목 | 값 |
|------|-----|
| 작업 | ${FEATURE} |
| 브랜치 | \`${BRANCH_NAME}\` |
| 시작 | $(head -4 "${TIMELINE_FILE}" | grep "시작" | awk -F'\\*\\*' '{print $2}' || date "+%Y-%m-%d %H:%M:%S") |
| 종료 | $(date "+%Y-%m-%d %H:%M:%S") |
| 게이트 | ${GATE_LABEL} |
| 채점 키워드 | ${SCORED_COUNT_F}개 |
| fixable 키워드 | ${FIXABLE_F}개 |
| PR | ${PR_URL} |

## 주요 파일

| 파일 | 설명 |
|------|------|
| [TIMELINE.md](TIMELINE.md) | 단계별 실행 타임라인 |
| [plan.md](plan.md) | Architect 설계 계획 |
| [scores.json](scores.json) | 키워드별 채점 결과 (fixable 필드 포함) |
| [fix_search_keywords.sql](fix_search_keywords.sql) | ⚠️ DB 수정 SQL (미적용 — write 권한 확보 후 적용) |
| [fix_preview.md](fix_preview.md) | 수정 내용 미리보기 |
| [snapshot_before.md](snapshot_before.md) | search_keywords 스냅샷 (실행 전) |
| [snapshot_before_fix.csv](snapshot_before_fix.csv) | 수정 대상 키워드 스냅샷 |
| [impact_analysis.md](impact_analysis.md) | SQL 영향도 분석 |
| [git.log](git.log) | git 커밋/푸시 로그 |

## ⚠️ 다음 단계 (write 권한 확보 후)

1. fix_search_keywords.sql 검토 (impact_analysis.md 참고)
2. write 계정으로 SQL 실행: \`psql -U danble_write -d danble -f fix_search_keywords.sql\`
3. 검색 API 재호출로 개선 여부 확인
4. snapshot_after_fix.csv 저장 및 before/after 비교

리포트: \`${SQ_OUTPUT_DIR}/\`
SUMEOF

tl "✅ 완료 | PR: ${PR_URL}"

echo ""
echo "📤 릴리스 로그 최종 커밋/푸시..."
git add -A 2>/dev/null || true
if ! git diff --cached --quiet 2>/dev/null; then
  git commit -m "sq-v3: 릴리스 로그 — ${COMMIT_SUMMARY}

Co-Authored-By: Claude Sonnet 4.6 <noreply@anthropic.com>" 2>&1 | tee -a "${FLAG_DIR}/git.log" || true
  git push origin "${BRANCH_NAME}" 2>&1 | tee -a "${FLAG_DIR}/git.log" || true
  echo "  ✅ 릴리스 로그 푸시 완료"
else
  echo "  ⏭️  변경사항 없음 — 스킵"
fi

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  📋 실행 요약: ${SUMMARY_FILE}"
echo "  📋 타임라인: ${TIMELINE_FILE}"
echo ""
echo "  🔧 수정 SQL (미적용): ${FLAG_DIR}/fix_search_keywords.sql"
echo "  📄 수정 미리보기: ${FLAG_DIR}/fix_preview.md"
echo "  ⚠️  SQL은 read-only 계정으로 생성됨 — write 권한 확보 후 적용 필요"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
