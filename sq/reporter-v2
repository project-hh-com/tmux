3개 파일 모두 ${SQ_OUTPUT_DIR}/ 에 저장하세요.

작업 완료 후 반드시 실행: touch ${DONE_FILE}
REPORTERPROMPT

echo "📝 reporter-v2 시작..."
claude -p "$(cat "${PROMPT_FILE}")" --allowedTools "Read,Write,Edit,Bash,Glob,Grep" --dangerously-skip-permissions
