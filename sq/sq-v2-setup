#!/usr/bin/env bash
# sq-v2-setup — sq-v2 명령어 실행 환경 셋업
# 사용법: bash sq-v2-setup
#
# 수행 작업:
#   1. DB 자격증명은 sq-setup과 공유 (~/.config/sq/db.env)
#   2. sq-v2, reporter-v2 명령어를 PATH에 등록 (심볼릭 링크)
#   3. 연결 테스트 (기존 설정 재사용)

set -euo pipefail

SQ_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BIN_DIR="${HOME}/.local/bin"
SQ_DB_ENV="${HOME}/.config/sq/db.env"

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  🔧 sq-v2 환경 셋업"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# ── Step 1: DB 자격증명 확인 / 설정 ──────────────────────────
echo "1/3  DB 자격증명 확인..."

if [[ -f "${SQ_DB_ENV}" ]]; then
  echo "     ✅ 기존 sq 자격증명 발견: ${SQ_DB_ENV}"
  # shellcheck source=/dev/null
  source "${SQ_DB_ENV}"
else
  echo "     ⚠️  DB 자격증명 파일이 없습니다: ${SQ_DB_ENV}"
  echo "     sq-setup을 먼저 실행하거나, 지금 직접 입력하세요."
  echo ""
  read -r -p "     지금 입력하시겠습니까? [y/N] " SETUP_NOW
  if [[ "${SETUP_NOW}" =~ ^[Yy]$ ]]; then
    bash "${SQ_DIR}/sq-setup"
    source "${SQ_DB_ENV}"
  else
    echo "     ❌ DB 자격증명 없이는 sq-v2를 실행할 수 없습니다."
    echo "        bash sq-setup 을 먼저 실행하세요."
    exit 1
  fi
fi

# ── Step 2: DB 연결 테스트 ────────────────────────────────────
echo ""
echo "2/3  danble DB 연결 테스트..."
DB_TEST=$(PGPASSWORD="${PGPASSWORD}" PGCONNECT_TIMEOUT=15 psql \
  -h "${PGHOST}" -U "${PGUSER}" -d "${PGDATABASE}" -p "${PGPORT}" \
  --no-password \
  -c "SELECT COUNT(*) FROM search_keywords LIMIT 1;" \
  -t 2>&1 || true)

if echo "${DB_TEST}" | grep -qE "^[[:space:]]*[0-9]+"; then
  COUNT=$(echo "${DB_TEST}" | tr -d '[:space:]')
  echo "     ✅ DB 연결 성공! (search_keywords: ${COUNT}건)"
else
  echo "     ❌ DB 연결 실패 — VPN/네트워크 확인 후 재시도"
  echo "     ${DB_TEST}"
  exit 1
fi

# ── Step 3: sq-v2, reporter-v2 PATH 등록 ─────────────────────
echo ""
echo "3/3  sq-v2 명령어 PATH 등록..."
mkdir -p "${BIN_DIR}"

# sq-v2
SQ_V2_SCRIPT="${SQ_DIR}/sq-v2"
SQ_V2_LINK="${BIN_DIR}/sq-v2"
if [[ ! -f "${SQ_V2_SCRIPT}" ]]; then
  echo "     ❌ sq-v2 스크립트 없음: ${SQ_V2_SCRIPT}"
  exit 1
fi
chmod +x "${SQ_V2_SCRIPT}"
[[ -L "${SQ_V2_LINK}" ]] && rm "${SQ_V2_LINK}"
ln -s "${SQ_V2_SCRIPT}" "${SQ_V2_LINK}"
echo "     ✅ sq-v2:       ${SQ_V2_LINK} → ${SQ_V2_SCRIPT}"

# reporter-v2
REPORTER_V2_SCRIPT="${SQ_DIR}/reporter-v2"
REPORTER_V2_LINK="${BIN_DIR}/reporter-v2"
if [[ ! -f "${REPORTER_V2_SCRIPT}" ]]; then
  echo "     ❌ reporter-v2 스크립트 없음: ${REPORTER_V2_SCRIPT}"
  exit 1
fi
chmod +x "${REPORTER_V2_SCRIPT}"
[[ -L "${REPORTER_V2_LINK}" ]] && rm "${REPORTER_V2_LINK}"
ln -s "${REPORTER_V2_SCRIPT}" "${REPORTER_V2_LINK}"
echo "     ✅ reporter-v2: ${REPORTER_V2_LINK} → ${REPORTER_V2_SCRIPT}"

# PATH 등록 확인
if [[ ! ":$PATH:" == *":${BIN_DIR}:"* ]]; then
  echo "" >> "${HOME}/.zshrc"
  echo "# sq-v2 PATH — sq-v2-setup 추가" >> "${HOME}/.zshrc"
  echo "export PATH=\"${BIN_DIR}:\$PATH\"" >> "${HOME}/.zshrc"
  echo "     ~/.zshrc 에 PATH 추가됨 → source ~/.zshrc 실행 필요"
else
  echo "     ✅ ${BIN_DIR} 이미 PATH에 있음"
fi

# ── 완료 ─────────────────────────────────────────────────────
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  ✅ sq-v2 환경 셋업 완료!"
echo ""
echo "  사용법:  sq-v2"
echo "           sq-v2 \"특정 범위 지정\""
echo ""
echo "  reporter 단독 실행:"
echo "    FLAG_DIR=.agent/sq-v2-XXXX \\"
echo "    SQ_OUTPUT_DIR=docs/reports/sq-v2-XXXX \\"
echo "    reporter-v2"
echo ""
echo "  v1과 v2 차이점: $(dirname "${SQ_V2_SCRIPT}")/sq-v1-vs-v2.md"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
