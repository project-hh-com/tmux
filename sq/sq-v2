#!/usr/bin/env bash
# sq-v2 — Search Quality 워크플로 v2 (개선된 점수 체계)
# 사용법: sq-v2              → 40~50대 남성 패션 키워드 500개 검색 품질 평가 (기본값)
#         sq-v2 "범위 지정"  → 특정 카테고리나 범위를 지정해 실행
#
# v1 대비 주요 변경:
#   [B1] SQ_SEARCH_PARAMS에서 step, search_source 제거 (백엔드 스키마에 없는 파라미터)
#   [A1] FALLBACK 감지: total_count>1000→F강제 폐기 → POSSIBLE_FALLBACK으로 채점 계속
#   [A2] 이중의도 채점 → 의도 파악 정확도(유형 A/B/C/D/E별 채점)로 재설계
#   [A3] extracted_brands→관련성1.0 자동부여 폐기 → LLM 독립 평가
#   [A4] ZERO_RESULT → ZERO_UNRECOGNIZED / ZERO_NO_MATCH 하위 분류
#   점수 항목: 결과존재성(10)+검색범위적절성(15)+의도파악정확도(20)+결과관련성(30)+상위노출품질(20)+품절노출(5)=100점

set -euo pipefail

FEATURE="${1:-40~50대 남성 패션 키워드 500개 검색 품질 평가}"

