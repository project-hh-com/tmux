# ── 점수 비교 스냅샷 (eval-only 실행용) ─────────────────────
# eval-only 실행(opensearch/api 없이 runner+scorer+reporter만 실행)에서는
# DB 변경이 없으므로 before/after 스냅샷이 항상 동일.
# 대신 현재 scores.json과 가장 최근 이전 run의 scores.json을 비교.
compare_scores_with_previous() {
  local OUT_FILE="${FLAG_DIR}/snapshot_after.md"
  local CUR_SCORES="${FLAG_DIR}/scores.json"

  if [[ ! -f "$CUR_SCORES" ]]; then
    echo "  ⏭️  scores.json 없음 — 비교 스냅샷 스킵"
    return
  fi

  # 현재 실행 외의 가장 최근 scores.json 찾기
  local PREV_SCORES=""
  PREV_SCORES=$(find ".agent" -mindepth 2 -maxdepth 2 -name "scores.json" \
    ! -path "${FLAG_DIR}/*" 2>/dev/null | sort -r | head -1 || true)

  echo "  📊 이전 실행과 점수 비교 스냅샷 생성 (eval-only)..."
  [[ -n "$PREV_SCORES" ]] && echo "  ↩  이전 실행: ${PREV_SCORES}" || echo "  ↩  이전 실행 없음 (첫 실행)"

  python3 - > "${OUT_FILE}" 2>/dev/null << PYEOF
import json, os
from datetime import datetime

cur_path = '${CUR_SCORES}'
prev_path = '${PREV_SCORES}'

def load(p):
    try:
        return json.load(open(p, encoding='utf-8')) if p and os.path.exists(p) else []
    except Exception:
        return []

cur  = load(cur_path)
prev = load(prev_path)

def stats(data):
    if not data:
        return None
    scores = [d.get('score', 0) for d in data]
    segs   = {}
    grades = {}
    for d in data:
        segs[d.get('segment', 'GENERAL')]   = segs.get(d.get('segment', 'GENERAL'), 0)   + 1
        grades[d.get('grade', 'F')]          = grades.get(d.get('grade', 'F'), 0)         + 1
    return {
        'total': len(data),
        'avg':   round(sum(scores) / len(data), 2) if data else 0,
        'segs':  segs,
        'grades': grades,
    }

sc = stats(cur)
sp = stats(prev)

lines = []
lines.append(f"# 검색 품질 스냅샷 — after (eval-only 점수 비교) ({datetime.now().strftime('%Y-%m-%d %H:%M:%S')})")
lines.append("")
lines.append("> eval-only 실행 — DB 변경 없음. before/after 대신 현재 scores.json과 이전 실행 비교.")
lines.append(f"> 현재: {cur_path}")
lines.append(f"> 이전: {prev_path or '없음 (첫 실행)'}")
lines.append("")

lines.append("## 1. 전체 점수 비교")
lines.append("| 항목 | 이전 | 현재 | 변화 |")
lines.append("|------|------|------|------|")
if sc and sp:
    diff = round(sc['avg'] - sp['avg'], 2)
    lines.append(f"| 평균 점수 | {sp['avg']} | {sc['avg']} | {diff:+.2f} |")
    lines.append(f"| 키워드 수 | {sp['total']} | {sc['total']} | {sc['total']-sp['total']:+d} |")
elif sc:
    lines.append(f"| 평균 점수 | — | {sc['avg']} | (이전 없음) |")
    lines.append(f"| 키워드 수 | — | {sc['total']} | — |")
lines.append("")

lines.append("## 2. 세그먼트 비교")
lines.append("| 세그먼트 | 이전 | 현재 | 변화 |")
lines.append("|---------|------|------|------|")
for seg in ['GENERAL', 'FALLBACK', 'ZERO_RESULT']:
    c = (sc['segs'].get(seg, 0)  if sc else 0)
    p = (sp['segs'].get(seg, 0)  if sp else None)
    p_str  = str(p)  if p is not None else '—'
    d_str  = f"{c - p:+d}" if p is not None else '—'
    lines.append(f"| {seg} | {p_str} | {c} | {d_str} |")
lines.append("")

lines.append("## 3. 등급 분포 비교 (전체)")
lines.append("| 등급 | 이전 | 현재 | 변화 |")
lines.append("|------|------|------|------|")
for g in ['A', 'B', 'C', 'D', 'F']:
    c = (sc['grades'].get(g, 0) if sc else 0)
    p = (sp['grades'].get(g, 0) if sp else None)
    p_str = str(p)  if p is not None else '—'
    d_str = f"{c - p:+d}" if p is not None else '—'
    lines.append(f"| {g} | {p_str} | {c} | {d_str} |")
lines.append("")

# 키워드별 개선/하락 (이전 실행이 있을 때만)
if cur and prev:
    prev_map = {d['keyword']: d for d in prev}
    improved  = []
    regressed = []
    for d in cur:
        kw = d.get('keyword', '')
        if kw in prev_map:
            delta = d.get('score', 0) - prev_map[kw].get('score', 0)
            if delta > 5:
                improved.append((kw, prev_map[kw].get('score', 0), d.get('score', 0), delta))
            elif delta < -5:
                regressed.append((kw, prev_map[kw].get('score', 0), d.get('score', 0), delta))

    if improved:
        lines.append(f"## 4. 개선된 키워드 상위 10개 ({len(improved)}개 개선)")
        lines.append("| 키워드 | 이전 | 현재 | 변화 |")
        lines.append("|--------|------|------|------|")
        for kw, p, c, d in sorted(improved, key=lambda x: -x[3])[:10]:
            lines.append(f"| {kw} | {p} | {c} | +{d} |")
        lines.append("")

    if regressed:
        lines.append(f"## 5. 하락한 키워드 상위 10개 ({len(regressed)}개 하락)")
        lines.append("| 키워드 | 이전 | 현재 | 변화 |")
        lines.append("|--------|------|------|------|")
        for kw, p, c, d in sorted(regressed, key=lambda x: x[3])[:10]:
            lines.append(f"| {kw} | {p} | {c} | {d} |")
        lines.append("")

print('\n'.join(lines))
PYEOF
  local py_rc=$?
  if [[ $py_rc -ne 0 ]]; then
    echo "  ⚠️  비교 스냅샷 생성 실패 (exit ${py_rc})"
    return
  fi

  echo "  ✅ 비교 스냅샷 저장: ${OUT_FILE}"
}

# ── after 스냅샷 디스패처 ─────────────────────────────────────
# eval-only(opensearch/api 없는) 실행이면 점수 비교, 아니면 DB 스냅샷
snapshot_after() {
  if grep -qE '^(opensearch|api)\|' "${FLAG_DIR}/agents_wave_a.txt" 2>/dev/null; then
    # DB-modifying run: 기존 DB 상태 스냅샷
    take_snapshot "after"
  else
    # eval-only run: 이전 scores.json과 비교
    compare_scores_with_previous
  fi
}

# ── 사전 스냅샷 (Before) ─────────────────────────────────────
take_snapshot() {
  local LABEL="$1"        # before | after
  local OUT_FILE="${FLAG_DIR}/snapshot_${LABEL}.md"

  if [[ "$DB_AVAILABLE" != "true" ]]; then
    echo "  ⏭️  DB 미연결 — 스냅샷 스킵"
    return
  fi

  echo "  📸 검색 품질 스냅샷 (${LABEL})..."

  PGPASSWORD="${PGPASSWORD}" psql \
    -h "${PGHOST}" -U "${PGUSER}" -d "${PGDATABASE}" -p "${PGPORT}" \
    --no-password -t -A -F',' << SQLEOF > "${OUT_FILE}" 2>/dev/null || true
-- 스냅샷 헤더
SELECT '# 검색 품질 스냅샷 — ${LABEL} ($(date "+%Y-%m-%d %H:%M:%S"))';
SELECT '';

-- 1. 전체 키워드 현황
SELECT '## 1. 전체 키워드 현황';
SELECT '| 항목 | 값 |';
SELECT '|------|-----|';
SELECT '| 전체 키워드 수 | ' || COUNT(*) || ' |' FROM search_keywords WHERE is_deleted = false;
SELECT '| 결과 0건 키워드 | ' || COUNT(*) || ' |' FROM search_keywords WHERE result_product_count = 0 AND is_deleted = false;
SELECT '| 결과 0건 비율(%) | ' || ROUND(COUNT(*) * 100.0 / NULLIF((SELECT COUNT(*) FROM search_keywords WHERE is_deleted = false), 0), 2) || ' |' FROM search_keywords WHERE result_product_count = 0 AND is_deleted = false;
SELECT '';

-- 2. 점수 분포
SELECT '## 2. 점수 분포 (auto_score / md_score)';
SELECT '| 지표 | 평균 | 최솟값 | 최댓값 | 중앙값 |';
SELECT '|------|------|--------|--------|--------|';
SELECT '| auto_score | ' || ROUND(AVG(auto_score)::numeric,4) || ' | ' || MIN(auto_score) || ' | ' || MAX(auto_score) || ' | ' || ROUND(PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY auto_score)::numeric,4) || ' |' FROM search_keywords WHERE is_deleted = false;
SELECT '| md_score   | ' || ROUND(AVG(md_score)::numeric,4)   || ' | ' || MIN(md_score)   || ' | ' || MAX(md_score)   || ' | ' || ROUND(PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY md_score)::numeric,4)   || ' |' FROM search_keywords WHERE is_deleted = false;
SELECT '';

-- 3. rank 분포 (상위 10개)
SELECT '## 3. rank 상위 10개 키워드';
SELECT '| rank | keyword | result_product_count | auto_score |';
SELECT '|------|---------|----------------------|------------|';
SELECT '| ' || rank || ' | ' || keyword || ' | ' || result_product_count || ' | ' || ROUND(auto_score::numeric,4) || ' |'
FROM search_keywords WHERE is_deleted = false AND rank IS NOT NULL ORDER BY rank ASC LIMIT 10;
SELECT '';

-- 4. 카테고리별 0건 현황
SELECT '## 4. 카테고리별 0건 키워드 수 (상위 10개)';
SELECT '| category_main | 0건 키워드 수 | 전체 키워드 수 |';
SELECT '|--------------|-------------|-------------|';
SELECT '| ' || category_main || ' | ' || SUM(CASE WHEN result_product_count = 0 THEN 1 ELSE 0 END) || ' | ' || COUNT(*) || ' |'
FROM search_keywords WHERE is_deleted = false
GROUP BY category_main ORDER BY SUM(CASE WHEN result_product_count = 0 THEN 1 ELSE 0 END) DESC LIMIT 10;
SQLEOF

  echo "  ✅ 스냅샷 저장: ${OUT_FILE}"
}

take_snapshot "before"
echo ""

echo "📋 Phase 1: 설계 검토 및 에이전트 선택..."
echo ""
tl "📋 Phase 1 | Architect 시작"

cat > "${FLAG_DIR}/architect_prompt.txt" << PROMPTEOF
