  echo "  🎉 모든 게이트 통과!"
  tl "🔍 Phase 4 | ✅ 모든 게이트 통과"
else
  echo "  ⚠️  ${MAX_FIX_ROUNDS}회 자동 수정 후에도 게이트 실패"
  tl "🔍 Phase 4 | ❌ 게이트 실패 (${MAX_FIX_ROUNDS}회 보완 후)"
  echo "  로그: ${FLAG_DIR}/"
  echo "  (게이트 실패 상태로 PR을 Draft 생성합니다)"
fi
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# ── Phase 6: 릴리스 매니저 — 최종 커밋/푸시/PR 생성 ────────
# 게이트 통과 여부와 무관하게 항상 실행
# release-manager 정책:
#   - prd/main/master 베이스 금지
#   - 라벨 "Search Quality" 필수
#   - 게이트 실패 시 Draft PR 생성

# 에이전트 리포트 파일 목록 (존재하는 것만)
REPORT_FILES=""
[[ -f "${FLAG_DIR}/plan.md" ]]         && REPORT_FILES="${REPORT_FILES}\n- 설계 계획: ${FLAG_DIR}/plan.md"
[[ -f "${FLAG_DIR}/opensearch.log" ]]  && REPORT_FILES="${REPORT_FILES}\n- OpenSearch 분석: ${FLAG_DIR}/opensearch.log"
[[ -f "${FLAG_DIR}/api.log" ]]         && REPORT_FILES="${REPORT_FILES}\n- API 분석: ${FLAG_DIR}/api.log"
[[ -f "${FLAG_DIR}/runner.log" ]]      && REPORT_FILES="${REPORT_FILES}\n- 검색 실행 결과: ${FLAG_DIR}/runner.log"
[[ -f "${FLAG_DIR}/scorer.log" ]]      && REPORT_FILES="${REPORT_FILES}\n- 품질 점수: ${FLAG_DIR}/scorer.log"
[[ -f "${FLAG_DIR}/reporter.log" ]]    && REPORT_FILES="${REPORT_FILES}\n- 리포트 생성: ${FLAG_DIR}/reporter.log"

GATE_STATUS="통과"
$GATE_PASS || GATE_STATUS="실패 (Draft PR 생성)"

# commit_msg.txt 가 있으면 PR 제목으로 사용, 없으면 FEATURE 원문
COMMIT_SUMMARY=$(head -1 "${FLAG_DIR}/commit_msg.txt" 2>/dev/null | tr -d '\r\n' || echo "$FEATURE")

cat > "${FLAG_DIR}/release_manager_prompt.txt" << RMEOF
당신은 release-manager 에이전트입니다.
모든 분석/실행/평가 리포트를 통합해 최종 커밋·푸시·PR 생성을 마무리합니다.

## 작업 내용
원래 요청: ${FEATURE}
커밋/PR 제목용 요약: ${COMMIT_SUMMARY}
작업 브랜치: ${BRANCH_NAME}
CI 게이트 상태: ${GATE_STATUS}

## 에이전트 산출물 파일 (Read 툴로 직접 읽으세요)
$(printf "%b" "${REPORT_FILES}")

## 수행 절차

### Step 1. 상태 확인
git status
git log --oneline -5

### Step 2. 미커밋 변경 처리 (있을 경우)
git add -A 후 아래 형식으로 커밋:
  git commit -m "sq: ${COMMIT_SUMMARY}

Co-Authored-By: Claude Sonnet 4.6 <noreply@anthropic.com>"

커밋할 변경사항이 없으면 스킵.

### Step 3. 푸시
git push origin ${BRANCH_NAME}

### Step 4. PR 생성 또는 업데이트
기존 PR 확인:
  gh pr view --json url,number,baseRefName 2>/dev/null

기존 PR 없으면 신규 생성:
  - 베이스 브랜치: main
  - **prd/master 를 베이스로 절대 지정하지 마세요 — 해당 상황 발생 시 즉시 중단하고 결과 파일에 사유 기록**
  - 반드시 --label "Search Quality" 포함
  - CI 게이트 실패 상태면 --draft 플래그 추가
  - PR 제목: sq: ${COMMIT_SUMMARY}
  - PR 본문 구성:
    ## 요청
    ${FEATURE}
    ## Summary
    (plan.md 요약 — Read 툴로 읽어서 2-3줄로 요약)
    ## 에이전트 리포트
    (각 리포트 파일 핵심 내용 요약)
    ## CI 게이트
    상태: ${GATE_STATUS}
    ## Test plan
    - [ ] 검색 결과 정확도 개선 확인
    - [ ] 타입 에러 없음
    - [ ] 테스트 통과
    - [ ] 빌드 성공
    🤖 Generated with Claude Agent SQ (Search Quality)

기존 PR 있으면:
  gh pr edit --body "..." --add-label "Search Quality"
  (Draft 해제는 CI 통과 후 수동으로)

### Step 5. 결과 보고
${FLAG_DIR}/release_report.md 에 저장:
  # Release Report
  ## 브랜치: ${BRANCH_NAME}
  ## 커밋: (sha 목록)
  ## PR URL: https://github.com/.../pull/N
  ## 상태: 신규 생성 / 본문 업데이트 / Draft

## 금지 사항
- prd / master 를 베이스로 PR 생성 금지
- git push --force 금지
- .env* 파일 커밋 금지
- pre-commit 훅 우회(--no-verify) 금지
- 사용자에게 질문하지 마세요
RMEOF

tl "📦 Phase 6 | 릴리스 매니저 시작"
echo "📦 Phase 6: 릴리스 매니저 실행 중..."
echo ""
claude -p "$(cat "${FLAG_DIR}/release_manager_prompt.txt")" \
  --allowedTools "Read,Write,Edit,Bash,Glob,Grep" --dangerously-skip-permissions \
  2>&1 | tee "${FLAG_DIR}/release_manager.log"

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
if [[ -f "${FLAG_DIR}/release_report.md" ]]; then
  cat "${FLAG_DIR}/release_report.md"
else
  echo "  ℹ️  상세 로그: ${FLAG_DIR}/release_manager.log"
fi
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# ── SUMMARY.md 생성 ──────────────────────────────────────────
SUMMARY_FILE="${FLAG_DIR}/SUMMARY.md"
PR_URL=$(grep -o 'https://github.com[^ ]*pull/[0-9]*' "${FLAG_DIR}/release_manager.log" 2>/dev/null | head -1 || echo "(PR URL 미확인)")
SCORED_COUNT_F=$(python3 -c "import json,os; d=json.load(open('${FLAG_DIR}/scores.json')) if os.path.exists('${FLAG_DIR}/scores.json') else []; print(len(d))" 2>/dev/null || echo "0")
GATE_LABEL="✅ 통과"
$GATE_PASS || GATE_LABEL="❌ 실패"

cat > "${SUMMARY_FILE}" << SUMEOF
# sq 실행 요약

| 항목 | 값 |
|------|-----|
| 작업 | ${FEATURE} |
| 브랜치 | \`${BRANCH_NAME}\` |
| 시작 | $(head -4 "${TIMELINE_FILE}" | grep "시작" | awk -F'\\*\\*' '{print $2}' || date "+%Y-%m-%d %H:%M:%S") |
| 종료 | $(date "+%Y-%m-%d %H:%M:%S") |
| 게이트 | ${GATE_LABEL} |
| 채점 키워드 | ${SCORED_COUNT_F}개 |
| PR | ${PR_URL} |

## 주요 파일

| 파일 | 설명 |
|------|------|
| [TIMELINE.md](TIMELINE.md) | 단계별 실행 타임라인 |
| [plan.md](plan.md) | Architect 설계 계획 |
| [scores.json](scores.json) | 키워드별 채점 결과 |
| [snapshot_before.md](snapshot_before.md) | DB 스냅샷 (전) |
| [snapshot_after.md](snapshot_after.md) | DB 스냅샷 (후) |
| [impact_analysis.md](impact_analysis.md) | 영향도 분석 |
| [git.log](git.log) | git 커밋/푸시 로그 |

리포트: \`${SQ_OUTPUT_DIR}/\`
SUMEOF

tl "✅ 완료 | PR: ${PR_URL}"

# ── 최종 릴리스 로그 커밋/푸시 ───────────────────────────────
