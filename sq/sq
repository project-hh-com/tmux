curl 예시 (Python으로 배치 처리):
  python3 -c "
import urllib.request, urllib.parse, urllib.error, json, time, os, sys

def fetch_with_retry(url, kw, max_retry=3):
    delays = [1, 2, 4]
    for attempt in range(max_retry):
        try:
            res = json.loads(urllib.request.urlopen(url, timeout=10).read())
            items = res.get('data', {}).get('items', [])
            return {
                'keyword': kw,
                'result_count': len(items),
                'total_count': res.get('data', {}).get('total_count', 0),
                'product_ids': [x.get('product_display_id') for x in items],
                'brands': [x.get('brand', {}).get('label', '') for x in items],
                'error': None
            }, None
        except urllib.error.HTTPError as e:
            err = f'HTTP_{e.code}'
            if e.code == 429:
                wait = delays[min(attempt, len(delays)-1)] * 3
                print(f'  ⚠️  rate limit ({kw}) — {wait}s 대기 후 재시도', flush=True)
                time.sleep(wait)
            elif e.code >= 500:
                time.sleep(delays[min(attempt, len(delays)-1)])
            else:
                return None, err
        except urllib.error.URLError as e:
            err = f'URL_ERR:{e.reason}'
            time.sleep(delays[min(attempt, len(delays)-1)])
        except Exception as e:
            err = f'ERR:{e}'
            time.sleep(delays[min(attempt, len(delays)-1)])
    return None, err

keywords = open('${FLAG_DIR}/keywords_final.txt').read().splitlines()
os.makedirs('/tmp/search-quality', exist_ok=True)
base = '${SQ_SEARCH_ENDPOINT}?${SQ_SEARCH_PARAMS}'
total = len(keywords)
failed = []
skipped = 0
for i, kw in enumerate(keywords, 1):
    slug = urllib.parse.quote(kw, safe='')
    fname = '/tmp/search-quality/' + slug + '.json'
    if os.path.exists(fname):
        skipped += 1
        if i % 10 == 0 or i == total:
            print(f'  🏃 runner: {i}/{total} (건너뜀: {skipped}, 실패: {len(failed)})', flush=True)
        continue
    url = f'{base}&query={slug}'
    result, err = fetch_with_retry(url, kw)
    if result is None:
        result = {'keyword': kw, 'result_count': 0, 'total_count': 0, 'product_ids': [], 'brands': [], 'error': err}
        failed.append(f'{kw}\t{err}')
    open(fname, 'w').write(json.dumps(result, ensure_ascii=False))
    if i % 10 == 0 or i == total:
        print(f'  🏃 runner: {i}/{total} (건너뜀: {skipped}, 실패: {len(failed)})', flush=True)
    time.sleep(1)
if failed:
    open('${FLAG_DIR}/keywords_failed.txt', 'w').write('\n'.join(failed))
    print(f'  ⚠️  최종 실패 {len(failed)}개 → ${FLAG_DIR}/keywords_failed.txt', flush=True)
print(f'  ✅ runner 완료: {total}개 (건너뜀: {skipped}, 실패: {len(failed)})', flush=True)
"

