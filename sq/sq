FROM search_keywords WHERE is_deleted = false
GROUP BY category_main ORDER BY SUM(CASE WHEN result_product_count = 0 THEN 1 ELSE 0 END) DESC LIMIT 10;
SQLEOF

  echo "  ✅ 스냅샷 저장: ${OUT_FILE}"
}

