# ── 사전 스냅샷 (Before) ─────────────────────────────────────
take_snapshot() {
  local LABEL="$1"        # before | after
  local OUT_FILE="${FLAG_DIR}/snapshot_${LABEL}.md"

  if [[ "$DB_AVAILABLE" != "true" ]]; then
    echo "  ⏭️  DB 미연결 — 스냅샷 스킵"
    return
  fi

  echo "  📸 검색 품질 스냅샷 (${LABEL})..."

  PGPASSWORD="${PGPASSWORD}" psql \
    -h "${PGHOST}" -U "${PGUSER}" -d "${PGDATABASE}" -p "${PGPORT}" \
    --no-password -t -A -F',' << SQLEOF > "${OUT_FILE}" 2>/dev/null || true
-- 스냅샷 헤더
SELECT '# 검색 품질 스냅샷 — ${LABEL} ($(date "+%Y-%m-%d %H:%M:%S"))';
SELECT '';

-- 1. 전체 키워드 현황
SELECT '## 1. 전체 키워드 현황';
SELECT '| 항목 | 값 |';
SELECT '|------|-----|';
SELECT '| 전체 키워드 수 | ' || COUNT(*) || ' |' FROM search_keywords WHERE is_deleted = false;
SELECT '| 결과 0건 키워드 | ' || COUNT(*) || ' |' FROM search_keywords WHERE result_product_count = 0 AND is_deleted = false;
