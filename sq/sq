# ── PostgreSQL 접속 정보 — ~/.config/sq/db.env 에서 로드 ────
# 자격증명은 로컬 파일에만 보관 (git 비추적).
# 최초 설정: sq-setup 실행
SQ_DB_ENV="${HOME}/.config/sq/db.env"
if [[ -f "${SQ_DB_ENV}" ]]; then
  # shellcheck source=/dev/null
  source "${SQ_DB_ENV}"
else
  echo "⚠️  DB 자격증명 파일이 없습니다: ${SQ_DB_ENV}"
  echo "   sq-setup 을 먼저 실행해 환경을 설정하세요."
