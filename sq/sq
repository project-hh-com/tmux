    CLEAN_MSG=$(head -1 "${FLAG_DIR}/commit_msg.txt" | tr -d '\r\n')
  else
    CLEAN_MSG="$FEATURE"
  fi
  local FULL_MSG="${PREFIX}: ${CLEAN_MSG}"
  [[ -n "$PHASE" ]] && FULL_MSG="${FULL_MSG} — ${PHASE}"
  git add -A 2>/dev/null || true
  if git diff --cached --quiet 2>/dev/null; then
    echo "  ⏭️  변경사항 없음 — 커밋 스킵"
    return 0
  fi
  git commit -m "${FULL_MSG}

Co-Authored-By: Claude Sonnet 4.6 <noreply@anthropic.com>" 2>&1 | tee -a "${FLAG_DIR}/git.log" || true
  git push origin "$BRANCH_NAME" 2>&1 | tee -a "${FLAG_DIR}/git.log" || true
  echo "  ✅ 커밋/푸시 완료"
}

