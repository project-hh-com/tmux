#!/usr/bin/env bash
# sq — Search Quality 워크플로 (동적 에이전트 선택)
# 사용법: sq              → 40~50대 남성 패션 키워드 505개 검색 품질 평가 (기본값)
#         sq "범위 지정"  → 특정 카테고리나 범위를 지정해 실행

set -euo pipefail

FEATURE="${1:-40~50대 남성 패션 키워드 505개 검색 품질 평가}"

# ── PostgreSQL 접속 정보 — ~/.config/sq/db.env 에서 로드 ────
# 자격증명은 로컬 파일에만 보관 (git 비추적).
# 최초 설정: sq-setup 실행
SQ_DB_ENV="${HOME}/.config/sq/db.env"
if [[ -f "${SQ_DB_ENV}" ]]; then
  # shellcheck source=/dev/null
  source "${SQ_DB_ENV}"
else
  echo "⚠️  DB 자격증명 파일이 없습니다: ${SQ_DB_ENV}"
  echo "   sq-setup 을 먼저 실행해 환경을 설정하세요."
  echo "   에이전트는 DB 없이 동작합니다."
fi

# 기본값 폴백 (db.env 가 없어도 스크립트가 중단되지 않도록)
PGHOST="${PGHOST:-}"
PGDATABASE="${PGDATABASE:-danble}"
PGUSER="${PGUSER:-danble_read_only}"
PGPASSWORD="${PGPASSWORD:-}"
PGPORT="${PGPORT:-5432}"
PGSSLMODE="${PGSSLMODE:-require}"
export PGHOST PGDATABASE PGUSER PGPASSWORD PGPORT PGSSLMODE

# psql 유틸리티 alias (에이전트 스크립트에서 그대로 복붙 가능)
SQ_PSQL="psql -h ${PGHOST} -U ${PGUSER} -d ${PGDATABASE} -p ${PGPORT}"

# 주요 검색 관련 테이블 목록 (에이전트 프롬프트에 삽입)
# 런타임에 변수 확장 — 비밀번호는 스크립트 파일에 기록되지 않음
DB_SCHEMA_CONTEXT=$(cat << 'DBSCHEMAEOF'
## PostgreSQL DB 접근 (danble read-only replica)

접속 명령어 (Bash 툴에서 직접 실행 가능):
  PGPASSWORD="${PGPASSWORD}" psql -h "${PGHOST}" -U "${PGUSER}" -d "${PGDATABASE}" -p "${PGPORT}" --no-password -c "SELECT ..."

