# ── 브랜치 생성 ─────────────────────────────────────────────
# Feature 설명에서 ASCII 영숫자만 추출해 슬러그로 사용
BRANCH_SLUG=$(printf '%s' "$FEATURE" | LC_ALL=C tr -dc 'a-zA-Z0-9 ' | tr ' ' '-' | \
              tr '[:upper:]' '[:lower:]' | sed 's/--*/-/g' | sed 's/^-\|-$//g' | cut -c1-40)
[[ -z "$BRANCH_SLUG" ]] && BRANCH_SLUG="sq"
BRANCH_NAME="sq/${BRANCH_SLUG}-${TIMESTAMP}"

# 현재 브랜치 확인 — 보호 브랜치면 새 브랜치 생성, 아니면 현재 브랜치 사용
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
