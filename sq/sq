SELECT '';

-- 2. 점수 분포
SELECT '## 2. 점수 분포 (auto_score / md_score)';
SELECT '| 지표 | 평균 | 최솟값 | 최댓값 | 중앙값 |';
SELECT '|------|------|--------|--------|--------|';
SELECT '| auto_score | ' || ROUND(AVG(auto_score)::numeric,4) || ' | ' || MIN(auto_score) || ' | ' || MAX(auto_score) || ' | ' || ROUND(PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY auto_score)::numeric,4) || ' |' FROM search_keywords WHERE is_deleted = false;
SELECT '| md_score   | ' || ROUND(AVG(md_score)::numeric,4)   || ' | ' || MIN(md_score)   || ' | ' || MAX(md_score)   || ' | ' || ROUND(PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY md_score)::numeric,4)   || ' |' FROM search_keywords WHERE is_deleted = false;
SELECT '';

-- 3. rank 분포 (상위 10개)
SELECT '## 3. rank 상위 10개 키워드';
SELECT '| rank | keyword | result_product_count | auto_score |';
SELECT '|------|---------|----------------------|------------|';
