        items = res.get('data', {}).get('items', [])
        result = {
            'keyword': kw,
            'result_count': len(items),
            'total_count': res.get('data', {}).get('total_count', 0),
            'product_ids': [x.get('product_display_id') for x in items],
            'brands': [x.get('brand', {}).get('label', '') for x in items],
            'error': None
        }
    except Exception as e:
        result = {'keyword': kw, 'result_count': 0, 'total_count': 0, 'product_ids': [], 'brands': [], 'error': str(e)}
    fname = '/tmp/search-quality/' + urllib.parse.quote(kw, safe='') + '.json'
    open(fname, 'w').write(json.dumps(result, ensure_ascii=False))
    time.sleep(1)
"

