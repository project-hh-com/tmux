# 대신 현재 scores.json과 가장 최근 이전 run의 scores.json을 비교.
compare_scores_with_previous() {
  local OUT_FILE="${FLAG_DIR}/snapshot_after.md"
  local CUR_SCORES="${FLAG_DIR}/scores.json"

  if [[ ! -f "$CUR_SCORES" ]]; then
    echo "  ⏭️  scores.json 없음 — 비교 스냅샷 스킵"
    return
  fi

  # 현재 실행 외의 가장 최근 scores.json 찾기
  local PREV_SCORES=""
  PREV_SCORES=$(find ".agent" -mindepth 2 -maxdepth 2 -name "scores.json" \
    ! -path "${FLAG_DIR}/*" 2>/dev/null | sort -r | head -1 || true)

  echo "  📊 이전 실행과 점수 비교 스냅샷 생성 (eval-only)..."
  [[ -n "$PREV_SCORES" ]] && echo "  ↩  이전 실행: ${PREV_SCORES}" || echo "  ↩  이전 실행 없음 (첫 실행)"

  python3 - > "${OUT_FILE}" 2>/dev/null << PYEOF
import json, os
from datetime import datetime

cur_path = '${CUR_SCORES}'
prev_path = '${PREV_SCORES}'

def load(p):
    try:
        return json.load(open(p, encoding='utf-8')) if p and os.path.exists(p) else []
    except Exception:
        return []

cur  = load(cur_path)
prev = load(prev_path)

def stats(data):
    if not data:
        return None
    scores = [d.get('score', 0) for d in data]
    segs   = {}
    grades = {}
    for d in data:
        segs[d.get('segment', 'GENERAL')]   = segs.get(d.get('segment', 'GENERAL'), 0)   + 1
        grades[d.get('grade', 'F')]          = grades.get(d.get('grade', 'F'), 0)         + 1
    return {
        'total': len(data),
        'avg':   round(sum(scores) / len(data), 2) if data else 0,
        'segs':  segs,
        'grades': grades,
    }

sc = stats(cur)
sp = stats(prev)

lines = []
lines.append(f"# 검색 품질 스냅샷 — after (eval-only 점수 비교) ({datetime.now().strftime('%Y-%m-%d %H:%M:%S')})")
lines.append("")
lines.append("> eval-only 실행 — DB 변경 없음. before/after 대신 현재 scores.json과 이전 실행 비교.")
lines.append(f"> 현재: {cur_path}")
lines.append(f"> 이전: {prev_path or '없음 (첫 실행)'}")
lines.append("")

lines.append("## 1. 전체 점수 비교")
lines.append("| 항목 | 이전 | 현재 | 변화 |")
lines.append("|------|------|------|------|")
if sc and sp:
    diff = round(sc['avg'] - sp['avg'], 2)
    lines.append(f"| 평균 점수 | {sp['avg']} | {sc['avg']} | {diff:+.2f} |")
    lines.append(f"| 키워드 수 | {sp['total']} | {sc['total']} | {sc['total']-sp['total']:+d} |")
elif sc:
    lines.append(f"| 평균 점수 | — | {sc['avg']} | (이전 없음) |")
    lines.append(f"| 키워드 수 | — | {sc['total']} | — |")
lines.append("")

lines.append("## 2. 세그먼트 비교")
lines.append("| 세그먼트 | 이전 | 현재 | 변화 |")
lines.append("|---------|------|------|------|")
for seg in ['GENERAL', 'FALLBACK', 'ZERO_RESULT']:
    c = (sc['segs'].get(seg, 0)  if sc else 0)
    p = (sp['segs'].get(seg, 0)  if sp else None)
    p_str  = str(p)  if p is not None else '—'
    d_str  = f"{c - p:+d}" if p is not None else '—'
    lines.append(f"| {seg} | {p_str} | {c} | {d_str} |")
lines.append("")

lines.append("## 3. 등급 분포 비교 (전체)")
lines.append("| 등급 | 이전 | 현재 | 변화 |")
lines.append("|------|------|------|------|")
for g in ['A', 'B', 'C', 'D', 'F']:
    c = (sc['grades'].get(g, 0) if sc else 0)
    p = (sp['grades'].get(g, 0) if sp else None)
    p_str = str(p)  if p is not None else '—'
    d_str = f"{c - p:+d}" if p is not None else '—'
    lines.append(f"| {g} | {p_str} | {c} | {d_str} |")
lines.append("")

# 키워드별 개선/하락 (이전 실행이 있을 때만)
if cur and prev:
    prev_map = {d['keyword']: d for d in prev}
    improved  = []
    regressed = []
    for d in cur:
        kw = d.get('keyword', '')
        if kw in prev_map:
            delta = d.get('score', 0) - prev_map[kw].get('score', 0)
            if delta > 5:
                improved.append((kw, prev_map[kw].get('score', 0), d.get('score', 0), delta))
            elif delta < -5:
                regressed.append((kw, prev_map[kw].get('score', 0), d.get('score', 0), delta))

    if improved:
        lines.append(f"## 4. 개선된 키워드 상위 10개 ({len(improved)}개 개선)")
        lines.append("| 키워드 | 이전 | 현재 | 변화 |")
        lines.append("|--------|------|------|------|")
        for kw, p, c, d in sorted(improved, key=lambda x: -x[3])[:10]:
            lines.append(f"| {kw} | {p} | {c} | +{d} |")
        lines.append("")

    if regressed:
        lines.append(f"## 5. 하락한 키워드 상위 10개 ({len(regressed)}개 하락)")
        lines.append("| 키워드 | 이전 | 현재 | 변화 |")
        lines.append("|--------|------|------|------|")
        for kw, p, c, d in sorted(regressed, key=lambda x: x[3])[:10]:
            lines.append(f"| {kw} | {p} | {c} | {d} |")
        lines.append("")

print('\n'.join(lines))
PYEOF
  local py_rc=$?
  if [[ $py_rc -ne 0 ]]; then
    echo "  ⚠️  비교 스냅샷 생성 실패 (exit ${py_rc})"
    return
