# ── 토론 함수 (Red → Blue → Judge, 최대 2라운드) ────────────
# 모든 대용량 파일은 경로만 전달 — 에이전트가 Read 툴로 직접 읽음
run_debate() {
  local TOPIC="$1"
  local CONTEXT_FILE="$2"
  local FOCUS="$3"          # plan | test | review
  local ALLOW_REWORK="${4:-0}"  # 1이면 REWORK 판정 허용
  local MAX_ROUNDS=2
  local ROUND=0
  local VERDICT="CONTINUE"

  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "  🗣️  토론: ${TOPIC}"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

  while [[ $ROUND -lt $MAX_ROUNDS ]] && [[ "$VERDICT" != "CONSENSUS" ]]; do
    ROUND=$((ROUND + 1))
    echo ""
    echo "  🔴 Round ${ROUND}/${MAX_ROUNDS} — Red 공격 중..."

    cat > "${FLAG_DIR}/red_${FOCUS}_${ROUND}.txt" << REDEOF
당신은 red 에이전트입니다. 아래 파일의 허점, 위험요소, 누락된 엣지케이스를 공격하세요.
해결책 제시 금지. 문제 지적만 하세요.

주제: ${TOPIC}
원본 작업: ${FEATURE}

검토 대상 파일 (Read 툴로 직접 읽으세요): ${CONTEXT_FILE}

공격 내용을 ${FLAG_DIR}/red_${FOCUS}_${ROUND}.md 에 저장하세요.
REDEOF
    claude -p "$(cat "${FLAG_DIR}/red_${FOCUS}_${ROUND}.txt")" \
      --allowedTools "Read,Write,Glob,Grep" --dangerously-skip-permissions 2>&1 | tee "${FLAG_DIR}/red_${FOCUS}_${ROUND}.log"

    echo "  🔵 Round ${ROUND}/${MAX_ROUNDS} — Blue 방어 중..."
    cat > "${FLAG_DIR}/blue_${FOCUS}_${ROUND}.txt" << BLUEEOF
당신은 blue 에이전트입니다. Red의 공격을 검토하고 각 항목을 ACCEPT/MITIGATE/REJECT로 판정하세요.
ACCEPT 또는 MITIGATE 항목은 실제로 파일을 수정해 반영하세요.

주제: ${TOPIC}
원본 작업: ${FEATURE}

검토 대상 파일 (Read 툴로 읽으세요): ${CONTEXT_FILE}
Red 공격 파일 (Read 툴로 읽으세요): ${FLAG_DIR}/red_${FOCUS}_${ROUND}.md

판정 및 수정 결과를 ${FLAG_DIR}/blue_${FOCUS}_${ROUND}.md 에 저장하세요.
BLUEEOF
    claude -p "$(cat "${FLAG_DIR}/blue_${FOCUS}_${ROUND}.txt")" \
      --allowedTools "Read,Write,Edit,Glob,Grep" --dangerously-skip-permissions 2>&1 | tee "${FLAG_DIR}/blue_${FOCUS}_${ROUND}.log"

    echo "  ⚖️  Round ${ROUND}/${MAX_ROUNDS} — Judge 판정 중..."
    cat > "${FLAG_DIR}/judge_${FOCUS}_${ROUND}.txt" << JUDGEEOF
당신은 judge 에이전트입니다. Red/Blue 토론을 심판하세요.

주제: ${TOPIC}
라운드: ${ROUND}/${MAX_ROUNDS}

Red 공격 파일 (Read 툴로 읽으세요): ${FLAG_DIR}/red_${FOCUS}_${ROUND}.md
Blue 방어 파일 (Read 툴로 읽으세요): ${FLAG_DIR}/blue_${FOCUS}_${ROUND}.md

판정 결과를 ${FLAG_DIR}/judge_${FOCUS}_${ROUND}.md 에 저장하고,
첫 번째 줄에 반드시 다음 형식으로 작성하세요:
VERDICT: CONSENSUS   (Blue가 충분히 방어/개선함 — 종료)
VERDICT: CONTINUE    (사소한 문제 — 다음 라운드에서 Blue가 수정)
$(if [[ "$ALLOW_REWORK" == "1" ]]; then echo "VERDICT: REWORK      (근본적 재구현 필요 — Wave 에이전트를 처음부터 다시 실행해야 함)"; fi)
JUDGEEOF
    claude -p "$(cat "${FLAG_DIR}/judge_${FOCUS}_${ROUND}.txt")" \
      --allowedTools "Read,Write,Edit" --dangerously-skip-permissions 2>&1 | tee "${FLAG_DIR}/judge_${FOCUS}_${ROUND}.log"

    VERDICT=$(grep "^VERDICT:" "${FLAG_DIR}/judge_${FOCUS}_${ROUND}.md" 2>/dev/null | head -1 | awk '{print $2}')
    VERDICT="${VERDICT:-CONTINUE}"
    echo "  ⚖️  판정: ${VERDICT}"
    # REWORK는 루프를 즉시 탈출 (다음 라운드 없이 Wave 재실행)
    [[ "$VERDICT" == "REWORK" ]] && break
  done

  echo ""
  case "$VERDICT" in
    CONSENSUS) echo "  ✅ CONSENSUS — 다음 단계로 진행" ;;
    REWORK)    echo "  🔄 REWORK — Wave 에이전트 재실행 필요" ;;
    *)         echo "  ⚠️  ${MAX_ROUNDS}라운드 종료 — 최선의 결과로 진행" ;;
  esac
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""

  # 최종 verdict를 파일로 저장 (호출부에서 REWORK 여부 확인용)
  echo "$VERDICT" > "${FLAG_DIR}/debate_${FOCUS}_verdict.txt"
}

# ── 웨이브 대기 함수 ─────────────────────────────────────────
# 형식: wait_wave <wave_file> <label>
# wave_file 행 형식: AGENT_NAME|EMOJI|SCRIPT_PATH
wait_wave() {
  local WAVE_FILE="$1"
  local WAVE_LABEL="$2"
  local WAVE_COUNT=0
  local WAIT_COUNT=0
  local MAX_WAIT=600

  [[ ! -s "$WAVE_FILE" ]] && return

  while IFS='|' read -r AGENT_NAME AGENT_EMOJI AGENT_SCRIPT; do
    WAVE_COUNT=$((WAVE_COUNT + 1))
  done < "$WAVE_FILE"

  while [[ $WAIT_COUNT -lt $MAX_WAIT ]]; do
    local DONE_COUNT=0
    while IFS='|' read -r AGENT_NAME AGENT_EMOJI AGENT_SCRIPT; do
      [[ -f "${FLAG_DIR}/${AGENT_NAME}.done" ]] && DONE_COUNT=$((DONE_COUNT + 1)) || true
    done < "$WAVE_FILE"
    [[ $DONE_COUNT -ge $WAVE_COUNT ]] && break
    printf "\r  ⏳ %s 완료: %d/%d  (%ds)   " "$WAVE_LABEL" "$DONE_COUNT" "$WAVE_COUNT" "$WAIT_COUNT"
    sleep 5
    WAIT_COUNT=$((WAIT_COUNT + 5))
  done
  echo ""
}

# ── 완료된 웨이브 패널/세션 정리 ─────────────────────────────
# 전역 변수 사용: PANE_ID_FILE, FLAG_DIR, TMUX, MAIN_PANE
cleanup_wave() {
  # tmux 패널 정리
  if [[ -n "${TMUX:-}" ]] && [[ -s "$PANE_ID_FILE" ]]; then
    while IFS= read -r PANE_ID; do
      tmux kill-pane -t "$PANE_ID" 2>/dev/null || true
    done < "$PANE_ID_FILE"
    > "$PANE_ID_FILE"
    tmux select-pane -t "$MAIN_PANE" 2>/dev/null || true
  fi
  # 백그라운드 세션 정리
  if [[ -f "${FLAG_DIR}/agent_sessions.txt" ]] && [[ -s "${FLAG_DIR}/agent_sessions.txt" ]]; then
    while IFS= read -r SESSION; do
      tmux kill-session -t "$SESSION" 2>/dev/null || true
    done < "${FLAG_DIR}/agent_sessions.txt"
    > "${FLAG_DIR}/agent_sessions.txt"
  fi
}

# ── tmux 웨이브 실행 함수 ────────────────────────────────────
# 레이아웃: [Plan] | [Wave A 에이전트 세로] | [Wave B 에이전트 세로]
# - 각 웨이브는 이전 웨이브 오른쪽에 가로로 붙음
# - 웨이브 내부는 세로로 분할
# 전역 변수 사용: MAIN_WIN, MAIN_PANE, CWD, PANE_ID_FILE, LAST_WAVE_ANCHOR_PANE
LAST_WAVE_ANCHOR_PANE=""

launch_wave_tmux() {
  local WAVE_FILE="$1"
  local WAVE_LABEL="$2"
  local WAVE_COUNT=0

  [[ ! -s "$WAVE_FILE" ]] && return

  while IFS='|' read -r AGENT_NAME AGENT_EMOJI AGENT_SCRIPT; do
    WAVE_COUNT=$((WAVE_COUNT + 1))
  done < "$WAVE_FILE"

  echo "  ▶ ${WAVE_LABEL} (${WAVE_COUNT}개) 시작..."

  local FIRST_AGENT_PANE=""
  local FIRST=1

  while IFS='|' read -r AGENT_NAME AGENT_EMOJI AGENT_SCRIPT; do
    local NEW_PANE
    if [[ $FIRST -eq 1 ]]; then
      if [[ -z "$LAST_WAVE_ANCHOR_PANE" ]]; then
        # 첫 웨이브: 메인 패널 오른쪽에 가로 분할
        tmux split-window -h -t "$MAIN_WIN" -c "$CWD"
      else
        # 이후 웨이브: 이전 웨이브 첫 패널 오른쪽에 가로 분할 (새 컬럼)
        tmux split-window -h -t "$LAST_WAVE_ANCHOR_PANE" -c "$CWD"
      fi
      NEW_PANE=$(tmux display-message -p '#{pane_id}')
      FIRST_AGENT_PANE="$NEW_PANE"
      FIRST=0
    else
      # 같은 웨이브 내: 첫 패널 기준 세로 분할
      NEW_PANE=$(tmux split-window -v -t "$FIRST_AGENT_PANE" -c "$CWD" -P -F '#{pane_id}')
    fi
    echo "$NEW_PANE" >> "$PANE_ID_FILE"
    tmux select-pane -t "$NEW_PANE" -T "${AGENT_EMOJI} ${AGENT_NAME}"
    tmux send-keys -t "$NEW_PANE" "bash '${AGENT_SCRIPT}'" Enter
  done < "$WAVE_FILE"

  # 이 웨이브의 앵커 저장 → 다음 웨이브가 오른쪽에 붙을 기준점
  LAST_WAVE_ANCHOR_PANE="$FIRST_AGENT_PANE"

  # main-vertical: Plan 왼쪽, 나머지 오른쪽에 균등 세로 배치
  tmux select-layout -t "$MAIN_WIN" main-vertical
  tmux select-pane -t "$MAIN_PANE"
}

