#!/usr/bin/env bash
# sq — Search Quality 워크플로 (동적 에이전트 선택)
# 사용법: sq "검색 품질 개선 설명"

set -euo pipefail

FEATURE="${1:-}"
if [[ -z "$FEATURE" ]]; then
  echo "사용법: sq \"검색 품질 개선 설명\""
  exit 1
